# Firebase project directory (contains firebase.json). Deploy runs from here.
# Example: C:\Users\you\OneDrive - Adobe\firebase
FIREBASE_PROJECT_DIR=

# Optional: override hosting files root (folder that gets uploaded to Hosting).
# If unset, server reads "public" from firebase.json (e.g. "firebase" or "public").
# Example: C:\Users\you\OneDrive - Adobe\firebase\firebase
FIREBASE_HOSTING_PUBLIC=

# Port for this local tool (default 3847)
PORT=3847
