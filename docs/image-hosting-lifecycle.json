{
  "lifecycle": {
    "rule": [
      {
        "action": { "type": "Delete" },
        "condition": {
          "age": 3,
          "matchesPrefix": ["scrapes/"],
          "isLive": true
        }
      },
      {
        "action": { "type": "Delete" },
        "condition": {
          "age": 7,
          "matchesPrefix": ["scrapes/"],
          "isLive": false
        }
      },
      {
        "action": { "type": "Delete" },
        "condition": {
          "numNewerVersions": 2
        }
      }
    ]
  }
}
