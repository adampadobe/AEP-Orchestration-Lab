{
  "rules": {
    "workspaceClaims": {
      "$slug": {
        ".read": "auth != null",
        ".write": "auth != null && (!data.exists() && newData.val() === auth.uid || data.exists() && data.val() === auth.uid && newData.val() === auth.uid)",
        ".validate": "$slug.matches(/^[-a-z0-9._]{2,48}$/) && newData.isString() && newData.val().matches(/^[-a-zA-Z0-9_]{2,128}$/)"
      }
    },
    "userWorkspaceOwners": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid",
        ".validate": "newData.isString() && newData.val().matches(/^[-a-z0-9._]{2,48}$/)"
      }
    },
    "userWorkspaces": {
      "$wid": {
        ".read": "auth != null && (auth.uid === $wid || root.child('workspaceClaims').child($wid).val() === auth.uid)",
        ".write": "auth != null && (auth.uid === $wid || root.child('workspaceClaims').child($wid).val() === auth.uid)"
      }
    }
  }
}
