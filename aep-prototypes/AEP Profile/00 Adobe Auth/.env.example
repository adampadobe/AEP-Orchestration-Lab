# Adobe I/O OAuth – copy this file to .env and fill in your values.
# Never commit .env or real secrets to version control.

# Required: from Adobe Developer Console (Project > Service Account)
ADOBE_CLIENT_ID=your_client_id_here
ADOBE_CLIENT_SECRET=your_client_secret_here

# IMS host (usually one of these)
# ims-na1.adobelogin.com  (North America)
# ims-na2.adobelogin.com
# ims-eu1.adobelogin.com  (Europe)
ADOBE_IMS_HOST=ims-na1.adobelogin.com

# Scopes (space-separated; must match your project in Adobe Developer Console)
ADOBE_SCOPES=openid session AdobeID read_organizations

# AEP / org context (for use in API calls)
# Same as Python adobe_ims_auth / Firebase secret ADOBE_IMS_ORG — either name works:
ADOBE_ORG_ID=your_org_id@AdobeOrg
# ADOBE_IMS_ORG=your_org_id@AdobeOrg
ADOBE_SANDBOX_NAME=your_sandbox_name

# Optional: you usually do NOT need a copy of this file if you already use either:
#   ~/.config/adobe-ims/credentials.env
#   ADOBE_CREDENTIALS_FILE=/path/to/credentials.env
#   .env at the AEP-Orchestration-Lab repo root (parent of aep-prototypes/)

# Optional: technical account ID (for reference)
# ADOBE_TECHNICAL_ACCOUNT_ID=xxx@techacct.adobe.com
