# Profile Viewer – search dataset (loaded when you run the server from this folder)
# Copy to .env and set. Do not commit .env.

# Required for search: profile dataset (table name or dataset ID in Query Service)
# Use qualified name (e.g. demo_system_website_profile_dataset_global_v1_2) or dataset ID (e.g. 67fcd98bfbb6632aee0c6b2e).
# Dataset IDs are resolved to qualified name via Catalog API.
AEP_QUERY_PROFILE_DATASET_ID=demo_system_website_profile_dataset_global_v1_2

# Optional: custom SQL. Use $search for the term and $table for the quoted table ref.
# Default uses _demoemea.identification.core.email and LIKE '%' || $search || '%'.
# AEP_QUERY_SEARCH_SQL=SELECT DISTINCT _demoemea.identification.core.email AS email FROM $table WHERE LOWER(CAST(_demoemea.identification.core.email AS STRING)) LIKE LOWER('%' || $search || '%') LIMIT 200

# Profile API – Update profile attributes. Copy to .env and set.
# Parity with a working Postman POST to AEP_PROFILE_STREAMING_URL:
#   Content-Type: application/json
#   sandbox-name: same as ADOBE_SANDBOX_NAME in ../00 Adobe Auth/.env (e.g. kirkham), or the sandbox selected in the Profile Viewer UI
#   x-adobe-flow-id: AEP_PROFILE_FLOW_ID
#   Authorization: Bearer <OAuth token> (from Adobe Auth)
#   x-api-key: AEP_PROFILE_STREAMING_API_KEY if set, else ADOBE_CLIENT_ID (match Postman {{API_KEY}} if they differ)
# (DCS streaming does not add x-gw-ims-org-id — same five headers as Postman.)
# DCS collection URL for profile streaming (Operational Profile schema).
AEP_PROFILE_STREAMING_URL=https://dcs.adobedc.net/collection/a8b78b230d3f48d0e3f75ae4b9376249effe996d139a613497066ae3f77caf4b
AEP_PROFILE_FLOW_ID=e5654ef9-0f14-420a-84a9-8c48506f0173
# Body shape: default is bare JSON { "_demoemea": { ... } } (same as Postman raw). Dataset/schema are not in the body.
# Set AEP_PROFILE_STREAMING_ENVELOPE=1 only if your dataflow requires DCS envelope (header + body.xdmEntity + datasetId).
# Dataset + schema IDs (used only in envelope mode):
# AEP_PROFILE_DATASET_ID=699323ce1b3a85affd7095fc
# AEP_PROFILE_SCHEMA_ID=https://ns.adobe.com/demoemea/schemas/3b2ed8566798bafa8078a0521a48b2973a02dc798af3ea61
# Legacy: AEP_PROFILE_STREAMING_BARE=0 forces envelope; AEP_PROFILE_STREAMING_BARE=1 forces bare.
# Optional: sandbox for DCS (default from Adobe Auth). Match Postman: kirkham
# AEP_PROFILE_SANDBOX_NAME=kirkham
# Optional: x-api-key for DCS streaming (if not set, uses Adobe Auth client ID). Postman uses: aepCusComvProfileDataFlows
# AEP_PROFILE_STREAMING_API_KEY=aepCusComvProfileDataFlows
# Optional: XDM top-level key in the JSON body (must match your profile streaming schema). Default _demoemea.
# AEP_PROFILE_XDM_KEY=_demoemea

# Optional: for Event Generator (stream experience events to AEP). Defaults match 02 Ingest Events dataflow.
# AEP_EVENT_STREAMING_URL=https://dcs.adobedc.net/collection/...
# AEP_EVENT_FLOW_ID=...
# AEP_EVENT_DATASET_ID=...
# AEP_EVENT_SANDBOX=kirkham
#
# Event Generator page: DCS collection URL (default in server.js). Flow/schema/dataset must match this inlet.
# AEP_EVENT_GENERATOR_STREAMING_URL=https://dcs.adobedc.net/collection/d7824b017e820f769cb6efe11330d650136377522b4e75515fdd14102a4a9449
# AEP_EVENT_GENERATOR_FLOW_ID=...          # defaults to AEP_EVENT_FLOW_ID
# AEP_EVENT_GENERATOR_SCHEMA_ID=...        # envelope header + xdmMeta; defaults to EVENT schema above
# AEP_EVENT_GENERATOR_DATASET_ID=...       # defaults to AEP_EVENT_DATASET_ID
# AEP_EVENT_GENERATOR_SANDBOX=...          # defaults to Adobe Auth sandbox

# Optional: for Events Trigger (event-triggers.json payloads). Uses AEP_EVENT_STREAMING_URL or AEP_PROFILE_STREAMING_URL if not set.
# Set to the streaming URL for the event schema (e.g. demoemea journey events).
# AEP_TRIGGER_STREAMING_URL=https://dcs.adobedc.net/collection/...
# AEP_TRIGGER_FLOW_ID=...

# Optional: Journey Optimizer campaign name lookup (event detail modal). Default: https://journey.adobe.io/campaign/campaigns
# Requires Adobe Journey Optimizer API in your Adobe Developer integration.
# CJM_CAMPAIGN_BASE=https://journey.adobe.io/campaign/campaigns

# Optional: Journey Optimizer journey name lookup (event detail modal). Default: https://journey.adobe.io/journey/journeys
# Uses journeyVersionID from messageExecution to resolve journey name.
# CJM_JOURNEY_BASE=https://journey.adobe.io/journey/journeys

# Optional: Path to journey-names.json (AJO system schema workaround). Default: ./journey-names.json
# The Query Service API does not return rows for the journeys table. Use sync-journey-names.js to populate.
# JOURNEY_NAMES_JSON=./journey-names.json

# Local folder tree (Firebase images page): absolute path on this computer. Takes priority over FIREBASE_HOSTING_PUBLIC.
# Use quotes if the path contains spaces (e.g. OneDrive - Adobe).
# LOCAL_HOSTING_FOLDER="C:/Users/kirkham/OneDrive - Adobe/firebase/firebase"
#
# Optional: Firebase deploy — project folder with firebase.json. Uploads also work with only LOCAL_HOSTING_FOLDER above.
# FIREBASE_PROJECT_DIR=C:/Users/kirkham/OneDrive - Adobe/firebase
# FIREBASE_HOSTING_PUBLIC=C:/Users/kirkham/OneDrive - Adobe/firebase/firebase
# Deploy uses: firebase deploy --only hosting --non-interactive (cwd = FIREBASE_PROJECT_DIR).
# Requires firebase on PATH (npm install -g firebase-tools). Optional: FIREBASE_CLI=full path to a .exe if you do not use PATH.
# FIREBASE_CLI=C:/path/to/firebase-tools-win.exe

# Optional: for Edge Network interact (/api/events/interact). Uses Bearer + x-api-key + x-gw-ims-org-id from 00 Adobe Auth.
# AEP_EDGE_INTERACT_URL=https://server.adobedc.net/ee/v2/interact?dataStreamId=a7f9f0c6-5729-44dd-9f00-62c0da687b03
# AEP_EDGE_ECID=62722406001178632594092146103219305888
