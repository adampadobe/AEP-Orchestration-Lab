rma":"^6.3.2","karma-chrome-launcher":"^3.1.0","karma-firefox-launcher":"^2.1.0","karma-jasmine":"^1.1.1","karma-jasmine-ajax":"^0.1.13","karma-safari-launcher":"^1.0.0","karma-sauce-launcher":"^4.3.6","karma-sinon":"^1.0.5","karma-sourcemap-loader":"^0.3.8","karma-webpack":"^4.0.2","load-grunt-tasks":"^3.5.2","minimist":"^1.2.0","mocha":"^8.2.1","sinon":"^4.5.0","terser-webpack-plugin":"^4.2.3","typescript":"^4.0.5","url-search-params":"^0.10.0","webpack":"^4.44.2","webpack-dev-server":"^3.11.0"},"browser":{"./lib/adapters/http.js":"./lib/adapters/xhr.js"},"jsdelivr":"dist/axios.min.js","unpkg":"dist/axios.min.js","typings":"./index.d.ts","dependencies":{"follow-redirects":"^1.14.0"},"bundlesize":[{"path":"./dist/axios.min.js","threshold":"5kB"}]}')},57093:function(e){"use strict";e.exports=JSON.parse('{"@context":"https://schema.org","@type":"FAQPage","@id":"https://www.oldmutual.co.za/business/goals/run/multisure/","mainEntity":[{"@type":"Question","name":"How do I claim?","acceptedAnswer":{"@type":"Answer","text":"At Old Mutual Insure, we believe that you should always have a positive claims experience. We aim for a speedy turnaround time and want the process to be as easy and stress-free for you as possible.  If you need to register a claim, you can do so by any of the following means:   Call us directly on 0860 24 7 365 and a consultant will guide you through the process You can also submit a claim by contacting your broker directly"}},{"@type":"Question","name":"Does business insurance cover riots and looting?","brand":"Old Mutual Insure","acceptedAnswer":{"@type":"Answer","text":"Losses suffered as a result of civil commotion, strikes, riots, and public disorder such as the looting witnessed in KwaZulu-Natal and parts of Gauteng in July 2021, are covered by a state-owned special risks insurer called Sasria. This cover, however, cannot be bought directly from Sasria. It must be taken through intermediaries who are insurance companies. Having a policy such as multisure business insurance can help as the Sasria cover can then be given as an add-on or value add to an underlying policy. If you have a multisure policy, you can ask that cover for riots and looting be added. To learn more about Sasria and how damages from looting are covered, read our article."}},{"@type":"Question","name":"What business insurance do I need?","brand":"Old Mutual Insure","acceptedAnswer":{"@type":"Answer","text":"Each business is unique, and the covers required will depend on the type of business and the processes involved.Generally, business insurance cover is required to protect your business assets against the risk of:  fire floods storms water damage theft financial loss as a result of damage to the business assets that causes interruption or temporary cessation to the business, and vehicle accidents/theft of vehicles.We also provide cover for when you, as a business owner, are sued for injuries caused to other people or damages their property etc.Speak to your broker or contact us on 0860 22 55 63 for advice on the cover most suited for your business."}},{"@type":"Question","name":"What happens if you don\'t have insurance on your business?","brand":"Old Mutual Insure","acceptedAnswer":{"@type":"Answer","text":"Without business insurance, any mishap such as a fire at your work premises, floods, theft, or a motor accident where your business vehicle is written-off, could be devastating to your business, and you could struggle to come back financially. It could take a long time for your business to recover, and meanwhile, debtors could come knocking on your door.Trust your multisure insurance policy to be that certain friend that helps cushion you in uncertain times."}},{"@type":"Question","name":"Do I need business insurance for a sole proprietorship?","brand":"Old Mutual Insure","acceptedAnswer":{"@type":"Answer","text":"All businesses need insurance. The need for insurance cover is even more if you’re a one-man business where all business needs and losses rest on your shoulders, and you have to single-handedly try to worm your way out of any trouble that befalls your business.Trust multisure business insurance to be that faithful all-seasons friend that stands by your side in stormy weather and dark days."}},{"@type":"Question","name":"How long does it take to get business insurance?","brand":"Old Mutual Insure","acceptedAnswer":{"@type":"Answer","text":"Getting a business insurance policy with us is quick and easy. Our trained and knowledgeable brokers and advisers with help you all the way."}},{"@type":"Question","name":"Can I insure more than one business?","brand":"Old Mutual Insure","acceptedAnswer":{"@type":"Answer","text":"The multisure business insurance policy allows you to cover more than one business under one policy and to have only one premium deducted from your bank account."}}]}')},16599:function(e){"use strict";e.exports=JSON.parse('{"@context":"https://schema.org","@type":"FAQPage","@id":"https://www.oldmutual.co.za/personal/solutions/bank-and-borrow/frequently-asked-questions/","mainEntity":[{"@type":"Question","name":"<p><strong>How do I activate my Money Account?</strong></p>","acceptedAnswer":{"@type":"Answer","text":"<p></p> <p>1) Click <a href=\\"https://secure.moneyaccount.co.za/\\" target=\\"_blank\\">here</a> to get to the Client Service Area</p><p> 2) Fill in your ID number and answer the security question</p> <p>3) You\'ll get a One-time Pin (OTP) sent to the cellphone number you registered with</p> <p>4) Fill in and submit the Pin we sent you</p> <p>5) Choose \'Money Account Activate Card\'</p> <p>6) Fill in the last 4 numbers of the card PAN number (the number on the front of your card) and your card pin</p> <p>7) Read and accept the Money Account Terms &amp; Conditions</p> <p>8) Click \'Next\'</p> <p>9) And, just like that, your Money Account card has been activated!</p></span>"}},{"@type":"Question","name":"<strong>How to put money in your Money Account</strong>","acceptedAnswer":{"@type":"Answer","text":"<p><strong>Electronic Fund Transfer (EFT)</strong></p> <p>You can EFT the money using your mobile banking app or internet banking. You’ll need the following details to do it this way:</p> <ul><li><strong>Account number</strong>: 10 or 11 digit number showed on your internet banking, cellphone banking and mobile app profiles</li><li><strong>Account type</strong>: Choose ‘Savings’</li><li><strong>Bank</strong>: Choose Bidvest Bank (Old Mutual Money Account is in association with Bidvest Bank)</li><li><strong>Branch code</strong>: Enter 462005</li><li><strong>Branch name</strong>: Enter Bidvest Bank (if required)</li></ul> <p><strong>Cash Deposit</strong></p> <p>There are two ways to deposit cash into your Money Account:</p> <li>With a WiCode sent to your phone, which you can get at Shoprite, Checkers, and Usave stores.</li> <li>By making a card deposit, which you can do at your nearest Pick n Pay or Boxer Store.</li>"}},{"@type":"Question","name":"<p><strong>How do I make a mobile deposit at Shoprite, Checkers or USave?</strong></p>","acceptedAnswer":{"@type":"Answer","text":"<p>1) Tell the cashier you want to make a mobile deposit</p> <p>2) Using Cellphone Banking, dial *120*257# or open your&nbsp;app and click on \'Cash Deposit\'</p> <p>3) Give the cashier the 7-digit WiCode sent to your phone</p> <p>4) Give the cash to the cashier</p> <p>5) Once your deposit has been finished, the cashier will give you a till slip to confirm that the money is going into your account.</p>"}},{"@type":"Question","name":"<p><strong>How do I make a card deposit at a Pick n Pay or Boxer store?</strong></p>","acceptedAnswer":{"@type":"Answer","text":"<p>1) Tell the cashier you want to make a deposit using your card.</p> <p>2) Tell the cashier how much you want that deposit to be.</p> <p>3) Give the cash to the cashier.</p> <p>4) Put your card into the card machine</p> <p>5) Enter your 4-digit card PIN</p>"}},{"@type":"Question","name":"<p><strong>Bank transfer and stop order</strong></p>","acceptedAnswer":{"@type":"Answer","text":"<p>Did you know, you can transfer money from an account with another bank to your Old Mutual Money Account? Go to that bank’s branch to make the transfer. You can also set up a stop order, which lets you pay a set amount into your account on a monthly basis. These are the details you’ll need:</p> <ul><li><strong>Account number</strong>: 10 or 11 digit number displayed on your internet banking, cellphone banking and mobile app profiles</li><li><strong>Account type</strong>: Choose ‘Savings’</li><li><strong>Bank</strong>: Choose Bidvest Bank (Old Mutual Money Account is in association with Bidvest Bank)</li><li><strong>Branch code</strong>: Enter 462005</li><li><strong>Branch name</strong>: Enter Bidvest Bank (if required)</li></ul> <p>And remember, you can cancel your stop order at any time.</p>"}},{"@type":"Question","name":"<p><strong>How to get your salary paid into your Old Mutual Money Account</strong></p>","acceptedAnswer":{"@type":"Answer","text":"<p>Make your life easier and up your bucks by switching your salary payment into your Money Account. This saves you time and energy making transfers and missing your chance to earn interest. Plus, this way, you can close your old account and save on the banking fees.</p> <p>We’ve made this easy. Take your cellphone and ID into an Old Mutual branch, and our staff will help you make the switch in no time.</p> <p>Give us a call on 0860 222 252 or email us at <a href=\\"mailto:moneyaccountsupport@oldmutual.com\\" target=\\"_blank\\">moneyaccountsupport@oldmutual.com</a> to find out more!</p>"}},{"@type":"Question","name":"<p><strong>How do I register and log into my app?</strong></p>","acceptedAnswer":{"@type":"Answer","text":"<p>Before you can use your mobile app, you need to register and login. It’ll only take a minute.</p> <p>1) Go to your home screen (on your phone) and launch the app</p> <p>2) Click on \'Money Account\'</p> <p>3) Enter your cell phone number (the number you used to open your Money Account)</p> <p>4) You will get an SMS. Click on the link in the message.</p> <p>5) A USSD message will then be sent to your phone. Press 1 to confirm.</p> <p>6) Enter your card PIN and then choose \'verify\'</p> <p>7) Enter your app PIN and choose \'Login\' (Don’t forget to keep your pin safe and private!)</p>"}},{"@type":"Question","name":"<p><strong>How do I buy data, airtime and electricity</strong></p>","acceptedAnswer":{"@type":"Answer","text":"<p>There’s no need to run to the store when you can top up data, airtime and electricity from the comfort of your couch. Simply watch this <a href=\\"https://www.youtube.com/watch?v=fnUwHFlI0WA&amp;feature=youtu.be\\" target=\\"_blank\\">how-to video</a> or follow the steps, below:</p> <p>1) Launch the Old Mutual Banking App</p> <p>2) Click on \'Money Account\'</p> <p>3) Log in using your details or fingerprint (if you’ve set up biometrics)</p> <p>4) Click on the \'Prepaid\' icon on the homescreen</p> <p>5) Choose what you want to buy (airtime, data, SMS bundle or electricity)<br></p> <p><br>To buy airtime, SMS, and data</p> <p>6) Choose the cellphone number you want to recharge</p> <p>7) Choose the network provider that you (or the other number) use</p> <p>8) Choose an amount/bundle</p> <p>9) Click ‘buy’</p> <p>10) Confirm your purchase<br></p> <p><br>To buy electricity</p> <p>6) Click ‘Add Meter’</p> <p>7) Fill in the meter number, meter name, and reference</p> <p>8) Click ‘Confirm’ and the voucher number will be sent to you</p>"}},{"@type":"Question","name":"<p><strong>Internet banking</strong></p>","acceptedAnswer":{"@type":"Answer","text":"<p>With internet banking, you can manage your money from anywhere you have a secure internet connection.</p> <ul><li>Buy electricity, data and airtime</li></ul><ul><li>Make payments and manage beneficiaries</li></ul><ul><li>Quickpay other Money Accounts for free</li></ul><ul><li>Send money to accounts at other banks using only a mobile number</li></ul><ul><li>Transfer funds between SWIPE and SAVE accounts</li></ul><ul><li>Manage savings functions</li></ul><ul><li>Turn your card on &amp; off for safety</li></ul> <p><strong>Your username and password</strong></p> <p>To log in to internet banking, click <a href=\\"https://secure.moneyaccount.co.za/\\" target=\\"_blank\\">here</a> and enter your username (your cellphone number) and password. You would have received your password when you opened your Money Account.</p>"}},{"@type":"Question","name":"<p><strong>USSD: Dial *120*257#</strong></p>","acceptedAnswer":{"@type":"Answer","text":"<p>After you’ve dialed the shortcode above, you will be asked to create or reset your cellphone banking PIN. This is not the same as your Old Mutual Banking App PIN or ATM PIN. To reset your cellphone banking PIN, choose the option to reset PIN after dialing the shortcode (You will need your card PIN). Alternatively, call 0860 222 252 or visit an Old Mutual branch for help.</p>"}},{"@type":"Question","name":"<p><strong>Guard your PIN when using an ATM</strong></p>","acceptedAnswer":{"@type":"Answer","text":"<p>Never accept help from a stranger when you’re using an ATM, especially if your card gets stuck (a sign that your card could have been skimmed). If an ATM doesn’t return your card, cancel or switch off your card straight away (using the Old Mutual Banking App, cellphone banking, or online banking).</p>"}},{"@type":"Question","name":"<p><strong>Where can you withdraw cash from?</strong></p>","acceptedAnswer":{"@type":"Answer","text":"<p>We encourage you to swipe because you have access to unlimited swipes with zero transactional fees. But we understand that there are times when you need to get cash, so we’ve made withdrawals easy for you.</p> <ul><li>You can withdraw cash from a Shoprite, Checkers, Usave or Pick \'n Pay store for just R2.00 per cash withdrawal.</li><li>You can perform a cash withdrawal only or you can withdraw cash with a purchase of goods. Just inform the cashier that you would like to process a cash withdrawal, hand your card to the cashier, and you will be asked to enter your card pin to proceed with the transaction. Please make sure that the cashier gives you the right amount of money.</li><li>You can withdraw cash from an Old Mutual ATM or any other SASWICH ATM. A withdrawal at another bank\'s ATM will cost more than a withdrawal at an Old Mutual ATM. See the complete list of<a href=\\"/om-docs/bltcfe112fb1973457f/money-account-fee-structure.pdf\\" target=\\"_blank\\"> Money Account transaction fees</a>.</li><li>The daily withdrawal limit is R5000 per day (Temporary Cash Limit - R10 000.)</li></ul>"}},{"@type":"Question","name":"<p><strong>Tap &amp; Pay less</strong></p>","acceptedAnswer":{"@type":"Answer","text":"<p>When you Tap &amp; Pay, you don\'t use your PIN. And if you don\'t use your PIN, no one can sneak a peek at your most important digits. Tap &amp; Pay transactions are also faster than swiping or dipping your card\'s chip.</p>"}},{"@type":"Question","name":"<p><strong>Get ahead of fraudsters</strong></p>","acceptedAnswer":{"@type":"Answer","text":"<p>If you suspect fraud on your account, or your card pin or online banking details have have gotten out, don’t wait:</p> <ul><li>Switch your card off using Old Mutual Banking App, internet banking or cellphone banking (USSD).</li><li>Call the Money Account Service Centre: 0860 222 252 (SA only) or +27 21 503 0303 (Outside SA) to report it</li><li>Visit an Old Mutual Branch as soon as possible to report a problem. You will need to bring your ID document and cellphone.</li></ul>"}},{"@type":"Question","name":"<p><strong>Be aware of phishing schemes</strong></p>","acceptedAnswer":{"@type":"Answer","text":"<p>Old Mutual will never send you an email asking you to click on a link to update your information and you should never follow one of these suspicious links or enter your information once you’ve opened those links. Don’t even open it. Some of these pages can look like the real thing, so be careful.</p>"}}]}')},26069:function(e){"use strict";e.exports=JSON.parse('{"@context":"https://schema.org","@type":"FAQPage","@id":"https://www.oldmutual.co.za/personal/solutions/bank-and-borrow/personal-loans/frequently-asked-questions/","mainEntity":[{"@type":"Question","name":"How do I apply for a personal loan?","acceptedAnswer":{"@type":"Answer","text":"You can apply <a href=\'/personal/solutions/bank-and-borrow/personal-loans/\'>online</a>, over the <a href=\'/contact-us/\'>phone</a> or at your closest <a href=\'/about/branch-locator/\'>branch</a>."}},{"@type":"Question","name":"What documents do I need to apply for a personal loan?","acceptedAnswer":{"@type":"Answer","text":"<ul><li>A valid South African identity document (ID).</li><li>A current payslip not older than one month.</li><li>Your bank statements for the last three months indicating three consecutive monthly salary deposits (the statements must not be older than 7 days).</li></ul>"}},{"@type":"Question","name":"How does a personal loan work?","acceptedAnswer":{"@type":"Answer","text":"Our <a href=\'https://www.oldmutual.co.za/personal/solutions/bank-and-borrow/personal-loans/\'>personal loans</a> works as follows: <ul><li>A minimum loan term of 3 months.</li><li>A maximum loan term of 72 months.</li><li>You could qualify for a personal loan of up to R250 000.</li><li>Your interest rate is fixed. The fixed rate gives you the benefit of knowing what your instalment will be for the duration of the term of your <a href=\'https://www.oldmutual.co.za/personal/solutions/bank-and-borrow/personal-loans/\'>personal loan</a>, irrespective of any changes in the repurchase rate by the Reserve Bank.</li><li>To apply for a loan over a period of 1 - 12 months, you need to be permanently employed at the same employer for at least 3 months.</li><li>To apply for a loan over a period of 13 - 72 months, you need to be permanently employed at the same employer for at least 12 months.</li><li>The interest rate applied is based on your affordability and personal credit profile.</li><li>Businesses do not qualify for a personal loan.</li><li>Your personal loan can be insured against death disability or retrenchment by taking out Credit Life Insurance. Credit Life Insurance is compulsory for loans with a term of 12 months and more.</li></ul>"}},{"@type":"Question","name":"What other requirements are there to apply for a personal loan?","acceptedAnswer":{"@type":"Answer","text":"<ul><li>You need to be at least 18 years old.</li><li>You need to earn at least R2 500 per month.</li><li>The term of your loan must end before you turn 60 years of age.</li></ul>"}},{"@type":"Question","name":"How much does a personal loan cost?","acceptedAnswer":{"@type":"Answer","text":"<p>Your loan installment consists of the following costs:</p> <ul><li><strong>Interest Rate</strong> - Each customer\'s situation is unique. The interest charged on your loan will be calculated based on your affordability and personal credit profile.</li><li><strong>Monthly Service Fee</strong> - A standard monthly service fee is applied to all loan accounts and is charged on a monthly basis.</li><li><strong>Credit Life Premium</strong> - A credit life premium is charged monthly (for loan terms 12 months and above) and the premium is based on the rand value of your loan at the time of application</li></ul>"}},{"@type":"Question","name":"When do I get my money?","acceptedAnswer":{"@type":"Answer","text":"If your loan application is successful, we will pay out the loan within 24 hours, once approved and will notify you via SMS."}},{"@type":"Question","name":"When will my debit order be processed if I take a loan?","acceptedAnswer":{"@type":"Answer","text":"<p>If you take a loan, your debit order will go off every month on your pay date or on the date when your salary is paid into your account.</p> <p>If a loan is paid out within 14 days of your next salary date, your first debit order will only be processed the following month.</p> <p>If a loan is paid out more than 14 days before your next salary date, your first debit order will be processed in the same month.</p>"}},{"@type":"Question","name":"How will I be able to access my loan statement?","acceptedAnswer":{"@type":"Answer","text":"You will be able to access your loan statement by visiting your nearest branch or calling the call centre on 0860 445 445."}},{"@type":"Question","name":"Can I apply if I have never had debt?","acceptedAnswer":{"@type":"Answer","text":"We look at your affordability and previous credit record when assessing your loan application, if you do not have previous debt we may not be able to proceed, but we will consider your personal circumstances and let you know what the outcome of your application is. You may only qualify for a small loan until you have built up a good track record."}},{"@type":"Question","name":"What kind of loans does Old Mutual offer?","acceptedAnswer":{"@type":"Answer","text":"<ul><li>Short-term loans, with a repayment period ranging from a one month term to 12 months.</li><li>Long term loans with a repayment period that ranges from 13 to 72 months. The long-term loans also offer a consolidation element that allows you to settle and combine your other existing debt into one loan.</li></ul>"}},{"@type":"Question","name":"What are the benefits of taking up a consolidation loan?","acceptedAnswer":{"@type":"Answer","text":"<ul><li>With only one repayment every month, it’s easier to manage your debt.</li><li>Having only one loan means you avoid multiple fee charges on multiple loans.</li><li>Consolidation helps you to get rid of revolving credit that has stuck with you for years.</li></ul>"}},{"@type":"Question","name":"Will I be able to settle my loan earlier than the agreed term?","acceptedAnswer":{"@type":"Answer","text":"You will definitely be able to pay your loan off earlier than the agreed term. Settling your loan sooner means that you will be saving money on interest and fees."}},{"@type":"Question","name":"Can applying for a loan have a negative impact on your credit score?","acceptedAnswer":{"@type":"Answer","text":"Shopping around for credit could potentially have a negative impact on your credit score if you apply for credit at multiple places at the same time. That is why you should carefully consider if you are really interested in taking up credit and where you would like to apply, before you start the process."}},{"@type":"Question","name":"Why would I take up a loan with Old Mutual instead of another credit provider?","acceptedAnswer":{"@type":"Answer","text":"At Old Mutual, we care about our customers and we are responsible in terms of how we grant credit to our customers. This means that we take extra care during the loan application process to ensure that our customers can afford the loan that they are applying for. We also care about granting a loan to a customer that meets their needs while not impacting their ability to meet their other obligations. At Old Mutual we don’t want to keep you in debt indefinitely, we would like to support your financial needs with the end goal being financial freedom."}},{"@type":"Question","name":"Why did Old Mutual venture into credit market?","acceptedAnswer":{"@type":"Answer","text":"At Old Mutual, we really strive to meet the needs of our customers. Expanding on the financial services that we offer, allows us to do that."}},{"@type":"Question","name":"What is credit life?","acceptedAnswer":{"@type":"Answer","text":"Credit life is an insurance policy that provides cover in respect of your loan in events such as death, disability or retrenchment. Credit Life Insurance is compulsory for loans with a term of 12 months and more."}},{"@type":"Question","name":"Does Old Mutual require credit life cover?","acceptedAnswer":{"@type":"Answer","text":"<p>Old Mutual Finance is entitled to require you to take out credit life insurance for loans with a term of 12 months and more to ensure the loan is repaid if you die, become disabled or are retrenched. Old Mutual has arranged a policy through OMART, which is an Old Mutual insurance company.</p> <p>You can either take this policy or provide your own policy when you apply. Not any policy will be accepted by Old Mutual Finance. It must be a policy that provides at least the same protection to you and Old Mutual Finance. Therefore, it must cover at least the outstanding balance in the case of death, or permanent disability. If you are temporarily disabled, it must cover the instalments for 12 months and if you are retrenched, it must cover the instalments for at least 12 months. It must also not have unreasonable exclusions or waiting periods.</p> <p>Exclusion and limitation in relation to the different covered events apply. For example, the policy will not pay out if:</p> <ul><li>you know that you will be retrenched when you take out the loan</li><li>you injure yourself on purpose or commit suicide; and</li><li>Your disability or death is as a result of existing medical conditions not disclosed that affected you 12 months before the commencement of cover under the policy.</li></ul> <p>Credit Life exclusions and limitations will be explained in detail during the loan applications process.</p><p>The credit life policy summary is available for you to read and you will get a copy when you loan agreement is concluded. The cost of the credit life cover will be shown to you when we provide you with the loan offer.</p><p>If you have any further questions regarding the credit life policy or you would like to use your own policy, we will refer you to a specialist to assist you, before we can finalise the loan. Please call them directly on 0860 000 886.</p>"}}]}')},45908:function(e){"use strict";e.exports=JSON.parse('{"@context":"https://schema.org","@type":"FAQPage","@id":"https://www.oldmutual.co.za/personal/solutions/bank-and-borrow/personal-loans/","mainEntity":[{"@type":"Question","name":"How does a personal loan work?","acceptedAnswer":{"@type":"Answer","text":"<ul><li>With a personal loan, you can borrow between R2000 and R250 000</li><li>Loans are repaid over a period between 3 and 72 months</li><li>Interest rates are fixed. This way you know what your installment will be for the duration of the repayment period irrespective of any changes in the repurchase rate set by the Reserve Bank.</li></ul>"}},{"@type":"Question","name":"When do I get my money?","acceptedAnswer":{"@type":"Answer","text":"<p>If your loan application is successful, we will pay out the loan within 24 hours* after it has been approved. *disbursement times may vary</p>"}},{"@type":"Question","name":"Will applying for a loan affect my credit score?","acceptedAnswer":{"@type":"Answer","text":"<p>Requesting multiple loan quotes in a short period of time may impact your credit score.</p>"}},{"@type":"Question","name":"How much does a personal loan cost?","acceptedAnswer":{"@type":"Answer","text":"<p>Your loan installment consists of the following costs: <ul><li><strong>Interest</strong> – your interest rate will depend on your affordability and personal credit profile. The maximum interest rate is equal to the repo rate plus 21%.</li><li><strong>Monthly service fee</strong> – a standard monthly service fee of R60 (excluding VAT) is applied to all loan accounts.</li><li><strong>Credit life premium</strong> – a credit life premium is charged monthly (for loan terms of 12 months and longer). This premium is based on the Rand value of your loan at the time of application.</li><li><strong>Initiation fee</strong> – a once-off initiation fee is applied to new loans. This is R165 plus 10% of the loan amount in excess of R1,000 (capped at R1,050 excluding VAT).</li></ul></p>"}},{"@type":"Question","name":"What other requirements are there when applying for a loan?","acceptedAnswer":{"@type":"Answer","text":"<ul><li>You need to earn at least R2500 per month</li><li>You need to be between the ages of 18 and 60 years old</li><li>You need to be a South African citizen</li><li>To apply for a loan, you need to have been permanently employed at the same employer for at least 3 months</li></ul>"}},{"@type":"Question","name":"Loan Repayment Calculator and General Disclaimer","acceptedAnswer":{"@type":"Answer","text":"<p>The use of the online calculator is discretionary and calculations are estimates. Old Mutual Finance gives no warranty, express or implied, as to the accuracy of such estimates and does not accept any liability for loss or damage of any nature whatsoever, which may result from the use and/or reliance of estimates provided by the calculator. All loans are subject to a full credit assessment.</p><p>Old Mutual loan offerings are made available through Old Mutual Finance (RF) (Pty) Ltd, a Licensed Financial Services and Registered Credit Provider (NCRCP35)</p><p>Payment options range from 3 to 72 months. Interest calculated monthly. A once-off initiation and admin fees apply. The maximum interest rate is 24.5% annually. Representative Example: Credit of R5,000 borrowed for 3 months. Total interest payable over loan period: R291.09. Once off initiation fee: R649.75. Monthly admin fee R69. Total Amount Payable: R6,147.84.</p>"}},{"@type":"Question","name":"Term and Conditions","acceptedAnswer":{"@type":"Answer","text":"<a href=\'https://www.oldmutual.co.za/om-docs/bltbb402c76793a955e/2022_Lending_Competition_Terms_and_Conditions.pdf\'>Read our competition terms and conditions here.</a>"}}]}')},61243:function(e){"use strict";e.exports=JSON.parse('{"@context":"https://schema.org","@type":"FAQPage","@id":"https://www.oldmutual.co.za/personal/solutions/funeral/","mainEntity":[{"@type":"Question","name":"What is funeral cover?","acceptedAnswer":{"@type":"Answer","text":"Funeral cover is an insurance policy where you pay a monthly premium, and it pays out a single amount when you (or a family member covered in the policy) dies. The amount paid out can be used towards expenses like a coffin, tombstone, and catering. This ensures that when the time comes to say goodbye, your family will have some money towards funeral costs and may not need to go into debt"}},{"@type":"Question","name":"Is life insurance better than a funeral plan?","acceptedAnswer":{"@type":"Answer","text":"When it comes to life and funeral insurance, one isn’t better than the other because both serve different needs when someone passes away. A funeral plan pays towards the expenses of a specific event: a funeral. Life insurance provides for a family financially for the long term when they lose a breadwinner. It’s important to consider both as an integral part of your financial planning, and it’s possible to have both types of cover. <br> <br> <a href=\'/articles/funeral-cover-vs-life-cover\'>Read more about the differences between life and funeral cover and why it’s important to have both.</a>"}},{"@type":"Question","name":"Can I take out a funeral plan for my parents or other extended family members?","acceptedAnswer":{"@type":"Answer","text":"Yes, you can take out a funeral plan for your parents or other extended family members (like in-laws, grandparents, aunts and uncles) if they are younger than the maximum age specified in the policy at application."}},{"@type":"Question","name":"What are the advantages of a funeral plan?","acceptedAnswer":{"@type":"Answer","text":"There are four advantages of having funeral cover: <ol><li>Avoid leaving your family desperate during a difficult time.</li><li>Avoid prolonging the process and give yourself peace of mind.</li><li>Avoid having your family go into debt when paying funeral expenses.</li><li>Have the convenience of cover that pays out quickly for those immediate funeral expenses.</li></ol> <p>Get more insight by <a href=\'/articles/3-reasons-to-have-a-funeral-plan\'>reading our article about why you should have a funeral plan</a>.</p>"}},{"@type":"Question","name":"Is there an age limit for funeral plans?","acceptedAnswer":{"@type":"Answer","text":"When you apply for a funeral plan, you must be younger than a certain age. The specific age depends on which funeral product you purchase."}},{"@type":"Question","name":"Can I have two funeral policies?","acceptedAnswer":{"@type":"Answer","text":"You can have more than one funeral policy, but it might not make sense financially to pay monthly premiums for two or more plans. <a href=\'/personal/find-adviser/\'>Speak to a financial adviser</a> to get advice on which funeral plan will be the most affordable for you, whilst covering the number of people you need it to."}}]}')},18020:function(e){"use strict";e.exports=JSON.parse('{"@context":"https://schema.org","@type":"FAQPage","@id":"https://www.oldmutual.co.za/personal/solutions/life-and-disability/life-insurance/","mainEntity":[{"@type":"FinancialProduct","name":"What are the terms and conditions for Life Insurance?","brand":"Old Mutual Insure","acceptedAnswer":{"@type":"Offer","text":"<p>These documents contain all the rules and disclosures related to the products and the benefits available on each. They are provided to you so that you can read all the information to make an informed decision about the products and whether you should apply for them or want to see all the information before you finalise your application. This is an indication of the contract you will receive if we accept your application but that contract will only include the benefits and options you have selected and we have accepted.</p><p>To download, click on the product name of the rules and disclosures you wish to see.</p>"}},{"@type":"FinancialProduct","name":"","brand":"Old Mutual Insure","acceptedAnswer":{"@type":"Offer","text":"<p><a href=\'https://www.oldmutual.co.za/om-docs/blt87245d5cb70bbea7/OMP-Life_Cover_RSA.pdf\'>Life Cover</a> - Pays a single amount when you die or are diagnosed with a terminal illness.</p><p><a href=\'https://www.oldmutual.co.za/om-docs/blt3eebf6e2ca4ee26d/OMP-Life_Income_Cover_RSA.pdf\'>Life Income Cover</a> - Pays a monthly amount for a specific term when you die.</p><p><a href=\'https://www.oldmutual.co.za/om-docs/blt6bcd8d134e7d1415/OMP-Last_Survivor_Cover_RSA.pdf\'>Life Survivor Cover</a> - Pays a single amount when the last of the two insured people dies or is diagnosed with a terminal illness.</p><p><a href=\'https://www.oldmutual.co.za/om-docs/blt3cd6667763c35f66/OMP-Accidental_Death_RSA.pdf\'>Accidental Death Cover</a> - Pays a single amount if you die because of an accident.</p>"}},{"@type":"FinancialProduct","name":"Do I pay extra if I want to add Disability or Illness Insurance?","brand":"Old Mutual Insure","acceptedAnswer":{"@type":"Offer","text":"<p>Yes, you do. Your premium may be more affordable if you add these products to your Old Mutual Protect Life Cover rather than buying them separately. It is important to note that any claims we pay on the added cover will reduce the cover amount on your Old Mutual Protect Life Cover. Buying this cover separately and claiming from it will not reduce the cover amount on your Old Mutual Protect Life Cover but you\'ll pay a separate premium for both products.</p><p>Learn more about Old Mutual <a href=\'https://www.oldmutual.co.za/personal/solutions/life-and-disability/disability-insurance/\'>Disability Insurance</a> and <a href=\'https://www.oldmutual.co.za/personal/solutions/health/severe-illness-insurance/\'>Illness Insurance.</a></p>"}},{"@type":"FinancialProduct","name":"How do I get Life Insurance?","brand":"Old Mutual Insure","acceptedAnswer":{"@type":"Offer","text":"<p>Our Life insurance products are available from your financial adviser. Unlike off-the-shelf products, our products are designed around what you need and what you can afford. Your adviser can help you build your customised cover. If you don\'t have an adviser please call us on 0860 60 60 60 or  <a href=\'https://www.oldmutual.co.za/personal/find-adviser\'> find an advisor here</a>.</p>"}},{"@type":"FinancialProduct","name":"What medical information is needed when I apply for cover?","brand":"Old Mutual Insure","acceptedAnswer":{"@type":"Offer","text":"<p>You have the option to get the following cover by simply answering a few questions about your health and lifestyle:<ul><li>Old Mutual Protect Life Cover of up to R3 million</li><li>Old Mutual Protect Life Income Cover of up to R10 000 monthly</li><li>Old Mutual Protect Last Survivor Cover of up to R1 million</li><li>Old Mutual Protect Accidental Death Cover up to the maximum cover amount of R2 million</li></ul></p><p>If you would like to apply for more cover and don\'t want to be limited to the cover options listed above then you will need to go for medical tests and share the medical reports with us.</p>"}},{"@type":"FinancialProduct","name":"What is accidental and non-accidental death?","brand":"Old Mutual Insure","acceptedAnswer":{"@type":"Offer","text":"<p>Accidental death is death resulting from an accident such as a car accident or drowning. Non-accidental death is death by natural causes such as illness or old age. Suicide is also considered a non-accidental death.        </p>"}},{"@type":"FinancialProduct","name":"When does my cover start?","brand":"Old Mutual Insure","acceptedAnswer":{"@type":"Offer","text":"<p>You\'re covered up to 30 days before your first premium is payable.</p>"}},{"@type":"FinancialProduct","name":"Is there anything else I should know?","brand":"Old Mutual Insure","acceptedAnswer":{"@type":"Offer","text":"<p><ul><li>If you stop paying premiums your cover stops (unless you have Premium Protection in which case payment of premiums will continue under certain conditions). It\'s important to get in touch with your adviser before this happens so that he or she can assist you with possible solutions.</li><li>As this product is not an investment, you will not receive your premiums back if you cancel it.</li></ul></p>"}}]}')},20423:function(e){"use strict";e.exports=JSON.parse('{"@context":"https://schema.org","@type":"FAQPage","@id":"https://www.oldmutual.co.za/personal/solutions/life-and-disability/life-plan-range/","mainEntity":[{"@type":"FinancialProduct","name":"How does the Money back guarantee work?","brand":"Old Mutual Insure","acceptedAnswer":{"@type":"Offer","text":"<p>Pure Life Plan:</p><p>Money back guarantee is a benefit amount (equal to all premiums paid) that is payable if the insured person:<ul><li>dies due to non-accidental (natural) causes during the first six months from the application date</li><li>dies due to suicide during the first two years of the benefit</li></ul></p><p>Life & Disability Plan:</p><p>Money back guarantee is a benefit amount (equal to all premiums paid) that is payable if the insured person:<ul><li>dies or becomes disabled due to non-accidental (natural) causes during the first six months from the application date</li><li>dies due to suicide during the first two years of the benefit</li>></ul></p><p>Accidental Death & Disability Plan:</p><p>Money back guarantee is a benefit amount (equal to all premiums paid up to the cover amount) that is be payable if the insured person: <ul><li>dies due to non-accidental (natural) causes during the lifetime of the benefit (including suicide)</li><li>becomes disabled due to non-accidental (natural) causes – (excluding attempted suicide) during the lifetime of the benefit</li></ul></p>"}},{"@type":"FinancialProduct","name":"Who qualifies for Old Mutual Life Plan range?","brand":"Old Mutual Insure","acceptedAnswer":{"@type":"Offer","text":"<p>You qualify if you are a permanent SA resident with a minimum age of 16 (if you are purchasing a plan through an adviser/broker) or 18 (if you are purchasing a plan over the phone) and a maximum age of 60.</p>"}},{"@type":"FinancialProduct","name":"I\'d like to know more about Premium holiday","brand":"Old Mutual Insure","acceptedAnswer":{"@type":"Offer","text":"<p>The Premium holiday is a policy benefit that allows the policyholder to miss up to 6 premiums during times of financial difficulty such as retrenchment, unemployment, maternity leave and study leave without the plan being cancelled. You can miss these premiums by taking either or both an automatic premium holiday and a requested premium holiday in any combination as long as in total you do not miss more than six.</p><p>Automatic premium holiday</p><p>If you miss a premium, to ensure that your plan is not cancelled and if you have not used up your premium holidays, we will give you an automatic premium holiday. You qualify for an automatic premium holiday after we have received your first premium. For the first six years of your plan, you can miss one premium per year this way. After the sixth year, you will not receive any additional automatic premium holidays but you do not lose the ones you have not taken.</p><p>If you did not want to use your automatic premium holiday and want to make up the missed premium, you must contact us to make arrangements to pay it.</p><p>Requested premium holiday</p><p>You qualify for the requested premium holiday once we have received at least six premiums from you. You must contact us to arrange your requested premium holiday at least one month before you want to miss the first premium.</p>"}},{"@type":"FinancialProduct","name":"I want to know more about the Cash back","brand":"Old Mutual Insure","acceptedAnswer":{"@type":"Offer","text":"<p>For every 60 premiums that we receive (e.g. after 60, 120, 180 and 240) and if you are alive at the time that the qualifying premium is received, we will give you cash back. This cash back will be equal to 5 times the last premium we received.</p>"}}]}')},18078:function(e){"use strict";e.exports=JSON.parse('{"@context":"https://schema.org","@type":"FAQPage","@id":"https://www.oldmutual.co.za/personal/solutions/life-and-disability/old-mutual-life-insurance/","mainEntity":[{"@type":"Question","name":"Why do I need Life Insurance?","acceptedAnswer":{"@type":"Answer","text":"Should anything happen to you and your salary stops being paid, think about the impact that will have on your family. How will they cope with monthly expenses such as bond and car repayments, groceries, school fees and medical aid? Your life insurance policy will pay out a sum of money to your nominated beneficiary/ies should you die. They can then use the money to settle debt and maintain their standard of living."}},{"@type":"Question","name":"How many beneficiaries can I add?","acceptedAnswer":{"@type":"Answer","text":"The good news is you can nominate as many beneficiaries as you want. The people that are most dependent on your income right now can benefit from it."}}]}')},66384:function(e){"use strict";e.exports=JSON.parse('{"@context":"https://schema.org","@type":"FAQPage","@id":"https://www.oldmutual.co.za/personal/solutions/life-and-disability/","mainEntity":[{"@type":"Question","name":"What is life insurance?","brand":"Old Mutual Insure","acceptedAnswer":{"@type":"Answer","text":"Life insurance is quite literally insurance on your life. You (the policyholder) agree to pay an insurer - like Old Mutual - a premium every month and in return the insurer will pay your beneficiaries a lump sum when you die.There are, at times, exceptions to this rule. If the insured person is suffering a terminal or critical illness a payment may be made."}},{"@type":"Question","name":"Why do I need life insurance?","brand":"Old Mutual Insure","acceptedAnswer":{"@type":"Answer","text":"Your regular income pays for certain things for your loved ones. If anything should happen to you, that income ceases. How will your family cope without that money? Having life insurance means that they can carry on paying the bills and making provision for their future.Some things life insurance money can be used for:  Living expenses Education costs Home loan repayments To settle debt"}},{"@type":"Question","name":"How does life insurance work?","brand":"Old Mutual Insure","acceptedAnswer":{"@type":"Answer","text":"You pay a monthly premium for an amount of cover that you and your financial adviser, or service provider, have agreed on. You can choose to have the cover paid out to your beneficiaries as a regular income or a lump sum.Some products give you the option to add disability and/or illness insurance to your life insurance cover.Life insurance is underwritten, which means when you apply, the insurer gathers and analyses more information about your health and lifestyle through questions and medical examinations. The healthier you and your lifestyle are, the lower your premium will be."}},{"@type":"Question","name":"Can I take life cover out for my parents?","brand":"Old Mutual Insure","acceptedAnswer":{"@type":"Answer","text":"Yes, you can take out life cover for your parents. They\'ll be listed as the insured persons in the contract and you\'ll be the premium payer. For more information on how to do this, please speak to a financial adviser"}},{"@type":"Question","name":"How long does life insurance take to pay out?","brand":"Old Mutual Insure","acceptedAnswer":{"@type":"Answer","text":"Pay out times differ. Old Mutual can only pay the cover amount once the claim requirements have been met. It\'s important to note that the claim amount will only be paid into a South African bank account."}},{"@type":"Question","name":"How much life insurance do I need?","brand":"Old Mutual Insure","acceptedAnswer":{"@type":"Answer","text":"There\'s no simple answer to this question. The very best thing to do is to sit with your financial adviser and allow him or her to guide you. Ideally you need to ensure:  That your debt is taken care of - personal debt as well as larger debt such as your home loan Your children have sufficient funds for their tuition and That your spouse/partner has enough for living expenses"}},{"@type":"Question","name":"When should I get life cover?","brand":"Old Mutual Insure","acceptedAnswer":{"@type":"Answer","text":"It\'s time to consider life cover if you have loved ones who are financially dependent on you. It could be a spouse/partner, children or family members that you are responsible for. By taking out life cover you are planning to provide for them financially should anything happen to you."}},{"@type":"Question","name":"What is disability cover and how does it work?","brand":"Old Mutual Insure","acceptedAnswer":{"@type":"Answer","text":"Disability cover is insurance that pays out a cover amount (either lump sum or monthly) if an illness or injury renders you: Permanently disabled and unable to work Permanently impaired Unable to take care of yourself"}}]}')},14510:function(e){"use strict";e.exports=JSON.parse('{"@context":"https://schema.org","@type":"FAQPage","@id":"https://www.oldmutual.co.za/personal/solutions/mywill/","mainEntity":[{"@type":"Question","name":"What happens if I pass on without a will?","acceptedAnswer":{"@type":"Answer","text":"If you pass away without a will, it means you die intestate and the law kicks in. It then takes time for your beneficiaries to get their inheritance. In the meantime, they may be struggling to pay the bills, including your funeral expenses."}},{"@type":"Question","name":"Can I change my will?","acceptedAnswer":{"@type":"Answer","text":"Yes, of course, we have made it simple for you to do so anytime, anywhere. In fact, it\'s a good idea to revisit your will every few years or when you go through life changes like having a child, getting married or divorced. You can write a new will or make changes to your existing one by visiting our website and following the same process again. Simply login to MyOldMutual to edit and manage your will at any time."}},{"@type":"Question","name":"What is an executor?","acceptedAnswer":{"@type":"Answer","text":"The role of an executor is to wrap your estate affairs as soon as possible. Old Mutual gives you the option to appoint an executor, at an additional extra fee. By doing so, you can have your will stored safely, and have your beneficiaries notified of the existence of your will after you pass."}},{"@type":"Question","name":"What happens to my will when I pass?","acceptedAnswer":{"@type":"Answer","text":"What happens to a will after the death of the person who wrote it depends on where it is stored. A will becomes a public document after the death of the testator."}},{"@type":"Question","name":"How much will it cost?","acceptedAnswer":{"@type":"Answer","text":"Old Mutual Will is a free will drafting service. Should you however require expert estate planning advice during the process of the drafting of your will, certain fees and charges may become payable. You also have the option to purchase the additional services available such as the collection and storage of your signed will, checking the Department of Home Affairs’ records to see whether you are still alive and/or the notification of a contact person in the event of your death. These additional services are not free. You will be able to get more information about the additional services and the fees that are charged for them online when accessing Old Mutual Will."}},{"@type":"Question","name":"Terms and conditions","acceptedAnswer":{"@type":"Answer","text":"<a href=\\"/personal/solutions/mywill/terms-and-conditions/\\">View the terms and conditions</a>"}}]}')},12012:function(e){"use strict";e.exports=JSON.parse('{"@context":"https://schema.org","@type":"FAQPage","@id":"https://www.oldmutual.co.za/personal/solutions/short-term-insurance/car-and-home/","mainEntity":[{"@type":"Question","name":"How do I claim?","acceptedAnswer":{"@type":"Answer","text":"For a fast and easy claims settlement process, call <strong>0861 24 7 365</strong> or visit our <a href=\\"/personal/solutions/short-term-insurance/old-mutual-insure-claims\\">Claims page</a>. For emergency assistance contact us on<strong> 0860 24 7 365</strong>"}},{"@type":"Question","name":"What value added benefits do I get with vehicle insurance?","acceptedAnswer":{"@type":"Answer","text":"By insuring your vehicle with <strong>all</strong> sure, you’ll automatically qualify for a range of additional benefits, including: <strong>Towing cost cover: </strong>covering the cost of towing if arranged through the Old Mutual Insure Swift Accident Management Solutions help desk on&nbsp;0860 24 7 365, should your insured vehicle be involved in an accident. <strong>Replacement cost cover: </strong>covering the cost of loss or damage to vehicle keys, locks and remote controls. <strong>Car hire cover: </strong>available for up to 30, 60, or 90 days, should you need a short-term replacement for your insured vehicle."}},{"@type":"Question","name":"What does replacement value mean?","acceptedAnswer":{"@type":"Answer","text":"The replacement value of goods is what it would cost you to replace all your belongings with similar brand-new ones at the time of a claim. When you submit a claim, your insurer will calculate the replacement value you should have insured yourself for. If you have insured your belongings for less than this amount, your insurer will only pay a part of your claim and you will be responsible for the difference."}},{"@type":"Question","name":"What is insurable interest?","acceptedAnswer":{"@type":"Answer","text":"To have an insurable interest in an item, you would stand to suffer direct, measurable, financial loss if the item were lost, damaged or destroyed. For example, if your TV set to the value of R2 000 has been stolen from your home, as the owner of the TV you would have suffered a measurable loss of R2 000 due to your having a financial (insurable) interest in the TV set."}},{"@type":"Question","name":"What does it mean to be under-insured?","acceptedAnswer":{"@type":"Answer","text":"Under-insurance means you don\'t have adequate insurance to cover the full replacement value of the assets you have insured. For example, let’s say you’ve insured your household contents for R80 000 and your house is broken into. Goods with a replacement value of R30 000 are stolen, which you claim under your home insurance policy with Old Mutual Insure. Following an assessment, it is found that the current replacement value of your total household goods before the theft was actually R100 000 and not R80 000 as insured. This means that you were under-insured by 20% and only 80% of your claim will be paid, i.e. R24 000 and not the R30 000 claimed."}},{"@type":"Question","name":"Why do I have to pay an excess if I claim?","acceptedAnswer":{"@type":"Answer","text":"An excess (also known as a deductible or first amount payable) is essentially an underwriting fee charged to minimise the number of small administratively expensive claims, or to reduce a loss ratio, and to impose a duty of care on the insured. Excesses are usually charged either as a percentage of a claim, or as a fixed amount. For example, if you lose your watch, valued at R800, and the excess applicable is R200, the claim will be settled in the amount of R600. However, if a burst pipe results in damage of R375 to a ceiling and the excess applicable is R500, the cost would be for your own account due to it being less than the R500 excess."}},{"@type":"Question","name":"What if my policy information changes?","acceptedAnswer":{"@type":"Answer","text":"Changes of information could affect your cover and your premium, and as such need to be communicated to us immediately. These changes could include moving to a new residence, changing the regular driver of your insured motor vehicle, convictions for offences relating to dishonesty (against you or someone covered under your policy) and allowing tenants to rent your property."}}]}')},81278:function(e){"use strict";e.exports=JSON.parse('{"@context":"https://schema.org","@type":"FAQPage","@id":"https://www.oldmutual.co.za/personal/solutions/wills-trusts-and-estates/","mainEntity":[{"@type":"Question","name":"What happens if I pass on without a will?","acceptedAnswer":{"@type":"Answer","text":"If you pass away without a will, it means you die intestate and the law kicks in. It then takes time for your beneficiaries to get their inheritance. In the meantime, they may be struggling to pay the bills, including your funeral expenses."}},{"@type":"Question","name":"What is the difference between an executor and a trustee?","acceptedAnswer":{"@type":"Answer","text":"While both roles involve carrying out the instructions of your will, their goals are different. An executor\'s aim is to wrap your affairs as soon as possible. A trustee is there to see that your wishes are carried out and manage your estate on behalf of your beneficiaries if necessary."}},{"@type":"Question","name":"What is estate tax?","acceptedAnswer":{"@type":"Answer","text":"Estate duty is the tax that is paid when transferring your estate or assets to your beneficiaries when you pass away. In South Africa the tax is 20% of your estate\'s taxable value."}},{"@type":"Question","name":"Can I change my will?","acceptedAnswer":{"@type":"Answer","text":"Yes, you can. In fact, it\'s a good idea to revisit your will every few years or when you go through life changes like having a child, getting married or divorced. You can <a href=\'/personal/solutions/mywill/\'>create a new will</a> or make changes to your existing one."}}]}')},56757:function(e){"use strict";e.exports=JSON.parse('{"@context":"https://schema.org","@type":"FAQPage","@id":"https://www.oldmutual.co.za/personal/solutions/retirement-plans/","mainEntity":[{"@type":"Question","name":"What is a retirement annuity and how does it work?","acceptedAnswer":{"@type":"Answer","text":"A retirement annuity is a long term investment that aims to help you provide for your retirement years. This investment takes the form of a policy with a product supplier (company) like Old Mutual. Typical retirement annuities require a monthly investment amount but there are a few that accept lump sums only, or both. "}},{"@type":"Question","name":"What are the benefits of a retirement annuity?","acceptedAnswer":{"@type":"Answer","text":"Benefits of a retirement annuity include: Your contributions are tax-deductible (up to a certain limit) With most retirement annuities you can choose which funds you would like to invest in If you die, your benefits will not be tied up in your estate but allocated to your dependants as determined by the trustees of the retirement fund You don’t pay any tax on the growth of the retirement savings"}},{"@type":"Question","name":"How many retirement annuities can I have?","acceptedAnswer":{"@type":"Answer","text":"You can have any number of retirement annuities but the tax benefit is only up to a certain limit."}},{"@type":"Question","name":"How much should I be saving for retirement?","acceptedAnswer":{"@type":"Answer","text":"A financial adviser is the person best positioned to help you calculate this amount. They look at your whole financial portfolio and assist with calculating how much you need when you retire which helps you assess how much you should be saving. If you would like an estimate, then try our retirement savings calculator. Remember to be realistic about how much you\'ll need when you retire. Some expenses might decrease (your home may be fully paid up so no mortgage repayments) while other expenses, such as healthcare, are likely to increase due to failing health the older we get. "}},{"@type":"Question","name":"Is a retirement annuity the same as a pension fund?","acceptedAnswer":{"@type":"Answer","text":"A pension fund is a retirement fund that receives frequent contributions (usually monthly) from you and your employer. A pension fund is chosen by your employer.You have to stay in the pension fund while working at the company. If you leave the company before retirement age then you exit the pension fund too. The company will pay out the money you have accrued. You can reinvest the money from your pension fund into your new employer\'s pension or provident fund, your own RA or a preservation fund (where it will grow until you retire). If you cash out your pension fund, you will be taxed."}},{"@type":"Question","name":"What happens when you reach retirement age?","acceptedAnswer":{"@type":"Answer","text":"When you retire, at age 55 or older, you’re allowed to take a maximum of one third as a cash lump sum (the cash lump sum is taxable) from your retirement annuity. The balance must be used to purchase an income annuity (the income annuity is taxable)."}},{"@type":"Question","name":"What is the difference between a life annuity and a retirement annuity?","acceptedAnswer":{"@type":"Answer","text":"A retirement annuity is the investment vehicle you use to save for your retirement. The retirement savings accumulated at retirement are then used to buy a life or living annuity (or a combination of the two) that pays you a regular income."}}]}')},37556:function(e){"use strict";e.exports=JSON.parse('{"@context":"https://schema.org","@type":"FAQPage","@id":"https://www.oldmutual.co.za/personal/solutions/short-term-insurance/travel-insurance/","mainEntity":[{"@type":"Question","name":"How easy it is to claim?","acceptedAnswer":{"@type":"Answer","text":"Super easy. Send the claim form directly to Europ Assistance by emailing assist@europassistance.co.za or <a href=\'https://services.ominsure.co.za/widgets/TravelSure.html\' target=\'_blank\'>click here to submit </a>online."}},{"@type":"Question","name":"Can I extend my policy if I decide to extend my stay?","acceptedAnswer":{"@type":"Answer","text":"Sure. We can extend a trip policy as long as you let us know before your policy expires."}},{"@type":"Question","name":"Do I have to pay for my travel medical emergencies directly?","acceptedAnswer":{"@type":"Answer","text":"If you are asked to pay for medication, it is easier to settle the payment directly – just be sure to keep your receipts and claim your cost once you’re back home."}},{"@type":"Question","name":"What are the benefits of travel insurance?","acceptedAnswer":{"@type":"Answer","text":"The main benefit of having travel insurance is that it provides cover for the costs and losses associated with travelling internationally and domestically. For example, if you experience emergency medical expenses due to an accident or illness while overseas, your luggage is lost or stolen, or your trip is cancelled or even curtailed."}},{"@type":"Question","name":"When should you get travel insurance?","acceptedAnswer":{"@type":"Answer","text":"Ideally you should purchase travel insurance as soon as you’ve paid for your trip. The reason for this is that you receive cover for trip cancellation from the earliest possible moment."}},{"@type":"Question","name":"Does travel insurance start immediately? From what point are you covered?","acceptedAnswer":{"@type":"Answer","text":"Yes, cover for trip cancellation and trip delay starts immediately and ends once you’ve gone through passport control when commencing your trip. The cover for the rest of the benefits starts when you go through passport control when you start your trip and ends when you go through passport control when you return to your country of origin."}}]}')}},function(e){e.O(0,[71869,46593],function(){return t=41568,e(e.s=t);var t});e.O()}]);
//# sourceMappingURL=app-99af67e8347d839e2b4e.js.map