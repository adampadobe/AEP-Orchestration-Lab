    "headers": [
      {
        "source": "/api/brand-scraper/**",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "private, no-store, max-age=0, must-revalidate"
          }
        ]
      },
      {
        "source": "/profile-viewer/**/*.html",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "max-age=0, must-revalidate"
          }
        ]
      },
      {
        "source": "/profile-viewer/experimentation-accelerator*",
