        "function": {
          "functionId": "provisioningFieldGroups",
          "region": "us-central1"
        }
      },
      {
        "source": "/api/provisioning/tenant-schema/patch",
        "function": {
          "functionId": "provisioningTenantSchemaPatch",
          "region": "us-central1"
        }
      },
      {
        "source": "/api/consent-infra/status",
