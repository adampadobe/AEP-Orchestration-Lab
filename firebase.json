{
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "database": {
    "rules": "database.rules.json"
  },
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "*.local"
      ]
    }
  ],
  "hosting": {
    "public": "web",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "redirects": [
      {
        "source": "/",
        "destination": "/profile-viewer/home.html",
        "type": 302
      },
      {
        "source": "/content-decision-live.html",
        "destination": "/profile-viewer/content-decision-live.html",
        "type": 301
      },
      {
        "source": "/content-decision-live-edge.html",
        "destination": "/profile-viewer/content-decision-live-edge.html",
        "type": 301
      },
      {
        "source": "/profile-viewer/aep-architecture-interactive.html",
        "destination": "/profile-viewer/aep-architecture-apps.html",
        "type": 301
      }
    ],
    "rewrites": [
      {
        "source": "/api/aep",
        "function": {
          "functionId": "aepProxy",
          "region": "us-central1"
        }
      },
      {
        "source": "/api/edge-decisioning/preview-launch-rule",
