.venv/
__pycache__/
*.pyc
.env
*.env

# Firebase (standalone deploy)
functions/node_modules/
web/profile-viewer/experience-decisioning-playground/node_modules/
.firebase/
firebase-debug.log
firebase-debug.*.log

# Vendored prototypes (npm)
aep-prototypes/**/node_modules/

# Root npm (repo scripts: vendor:spectrum-icons, etc.)
node_modules/

# Local-only Firestore restore payloads (do not commit secrets)
scripts/data/*-restore.local.json

# Build-stamp files generated by scripts/build-version.mjs at predeploy time.
# They contain the deployed git SHA + deployer info and are regenerated on
# every `firebase deploy`, so they must NOT be committed (would create
# constant merge churn). They're served / read at runtime only.
web/version.json
functions/version.json
