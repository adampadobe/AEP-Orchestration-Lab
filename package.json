{
  "name": "aep-orchestration-lab",
  "private": true,
  "description": "AEP Orchestration Lab – decisioning, profile tools, and vendored prototypes",
  "engines": {
    "node": ">=22 <26",
    "npm": ">=10"
  },
  "scripts": {
    "profile-viewer": "cd \"aep-prototypes/AEP Profile/03 Profile Viewer\" && npm start",
    "profile-viewer:install": "cd \"aep-prototypes/AEP Profile/00 Adobe Auth\" && npm install && cd \"../03 Profile Viewer\" && npm install",
    "sync-profile-viewer-ui": "rsync -a --delete \"web/profile-viewer/\" \"aep-prototypes/AEP Profile/03 Profile Viewer/public/\"",
    "upload-live-activities-rtdb": "npx -y firebase-tools@latest database:set /profileViewerConfig/liveActivitiesPostmanCollection \"./web/profile-viewer/data/live-activities.postman_collection.json\" --project aep-orchestration-lab --force",
    "build:edp": "cd \"web/profile-viewer/experience-decisioning-playground\" && npm install && npm run build",
    "vendor:spectrum-icons": "node scripts/build-spectrum-workflow-icons.cjs",
    "test:arch-line-e2e": "node web/profile-viewer/scripts/e2e-architecture-line-bend.mjs",
    "validate:architecture-logos-tags": "python3 scripts/validate-architecture-logos-tags.py",
    "validate:ecosystem-vendor-index": "python3 scripts/validate-ecosystem-vendor-index.py",
    "verify:profile-viewer-routes": "node scripts/verify-profile-viewer-routes.mjs",
    "restore:decision-lab:kirkham-preset": "node scripts/restore-decision-lab-config.mjs kirkham --preset=race-for-life-retail"
  },
  "devDependencies": {
    "@adobe/spectrum-css-workflow-icons": "^5.0.0",
    "playwright": "^1.49.1"
  }
}
