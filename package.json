{
  "name": "aep-orchestration-lab",
  "private": true,
  "description": "AEP Orchestration Lab – decisioning, profile tools, and vendored prototypes",
  "engines": {
    "node": ">=22 <26",
    "npm": ">=10"
  },
  "scripts": {
    "profile-viewer": "cd \"aep-prototypes/AEP Profile/03 Profile Viewer\" && npm start",
    "profile-viewer:install": "cd \"aep-prototypes/AEP Profile/00 Adobe Auth\" && npm install && cd \"../03 Profile Viewer\" && npm install",
    "sync-profile-viewer-ui": "rsync -a --delete \"web/profile-viewer/\" \"aep-prototypes/AEP Profile/03 Profile Viewer/public/\"",
    "upload-live-activities-rtdb": "npx -y firebase-tools@latest database:set /profileViewerConfig/liveActivitiesPostmanCollection \"./web/profile-viewer/data/live-activities.postman_collection.json\" --project aep-orchestration-lab --force",
    "build:edp": "cd \"web/profile-viewer/experience-decisioning-playground\" && npm install && npm run build",
    "build:eds-doc-starter-zip": "python3 scripts/build_eds_doc_starter_zip.py",
    "build:eds-quickstart": "([ -f tools/eds-quickstart/package.json ] || git submodule update --init tools/eds-quickstart) && cd tools/eds-quickstart && npm install && npm run build:standalone && rsync -a --delete --exclude='*.map' --exclude='*.LICENSE.txt' dist/ ../../web/profile-viewer/eds-quickstart/",
    "vendor:spectrum-icons": "node scripts/build-spectrum-workflow-icons.cjs",
    "test:arch-line-e2e": "node web/profile-viewer/scripts/e2e-architecture-line-bend.mjs",
    "validate:architecture-logos-tags": "python3 scripts/validate-architecture-logos-tags.py",
    "validate:ecosystem-vendor-index": "python3 scripts/validate-ecosystem-vendor-index.py",
    "verify:profile-viewer-routes": "node scripts/verify-profile-viewer-routes.mjs",
    "prepare:sky-llm-snapshot": "node scripts/prepare-sky-llm-snapshot.mjs",
    "prepare:sky-llm-brand-presence": "node scripts/prepare-sky-llm-brand-presence.mjs",
    "verify:experimentation-accelerator": "node scripts/verify-experimentation-accelerator-snapshot.mjs",
    "verify:context7-coverage": "node scripts/verify-context7-coverage.mjs",
    "deploy:check": "node scripts/predeploy-check.mjs",
    "deploy:stamp": "node scripts/build-version.mjs",
    "deploy:status": "node scripts/deploy-status.mjs",
    "deploy:sandbox": "CF_RUNTIME_SERVICE_ACCOUNT=sc-demo-sandbox-cf-runtime@adbe-gcp0819.iam.gserviceaccount.com npx -y firebase-tools@latest deploy --only functions,hosting -P sandbox",
    "deploy:production": "npx -y firebase-tools@latest deploy --only functions,hosting -P production",
    "restore:decision-lab:kirkham-preset": "node scripts/restore-decision-lab-config.mjs kirkham --preset=race-for-life-retail",
    "mcp:aep-lab-adobe": "node tools/aep-lab-adobe-mcp/src/server.mjs",
    "ajo:create-content-template": "node scripts/create-ajo-content-template.mjs",
    "aep:create-hotel-edge-segments": "node scripts/create-hotel-edge-segments.mjs"
  },
  "devDependencies": {
    "@adobe/spectrum-css-workflow-icons": "^5.0.0",
    "playwright": "^1.49.1"
  }
}
