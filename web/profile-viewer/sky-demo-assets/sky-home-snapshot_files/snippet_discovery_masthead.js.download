99-CECAF53ABDF5", "selector": "[data-tracking-description=\"cta:navigation\"]"}, {"css": {}, "dependencies": [], "attributes": {"html": "Subject to status. Offer ends 17 June. Based on 43\" TV. TV available with loan. Sky Sports optional extra. Sky TV: from \u00a315pm with a 24-month minimum term OR from \u00a318pm on a 30-day rolling contact. Prices may change during 24m contract"}, "type": "attribute", "id": "7B0EBBF4-61A1-4F26-BAEF-1C9B986B16B5", "selector": "[data-test-id='hero'] > p[data-skyui-core='Text@13.0.1']"}]}, {"viewId": "28370991178", "changes": [{"id": "0595F0F1-0F5B-4FA5-906D-418D5660F481", "type": "custom_code", "value": function($){(function () {
  var BODY_COPY_CARD_1 =
    'Get the best of Sky and Netflix in one place with Sky TV from only £15pm.';

  var SMALL_PRINT_CARD_1 =
    'Subject to status. Offer ends 17 June. Based on 43" TV. TV available with loan. Sky Sports optional extra. Sky TV: from £15pm with a 24-month minimum term OR from £18pm on a 30-day rolling contact. Prices may change during 24m contract';

  var BODY_COPY_CARD_2 =
    'Get the best of Sky and Netflix in one place with Sky TV from only £15pm.';

  var SMALL_PRINT_CARD_2 =
    'Subject to status. Offer ends 17 June. Based on 43" TV. TV available with loan. Sky Sports optional extra. Sky TV: from £15pm with a 24-month minimum term OR from £18pm on a 30-day rolling contact. Prices may change during 24m contract';

  var DEALS = {
    air: {
      card: { price: "237", vhText: "From £237 upfront", suffix: " upfront", bodyCopy: BODY_COPY_CARD_1, smallPrint: SMALL_PRINT_CARD_1 },
      modal: { price: "237", vhText: "From £237 upfront", suffix: " upfront", bodyCopy: BODY_COPY_CARD_1, smallPrint: SMALL_PRINT_CARD_1 }
    },
    byob: {
      card: { price: "555", vhText: "From £555 upfront", suffix: " upfront", bodyCopy: BODY_COPY_CARD_2, smallPrint: SMALL_PRINT_CARD_2 },
      modal: { price: "555", vhText: "From £555 upfront", suffix: " upfront", bodyCopy: BODY_COPY_CARD_2, smallPrint: SMALL_PRINT_CARD_2 }
    }
  };

  function setText(el, value) {
    if (!el || value == null) return;
    if (typeof el.innerText === "string") {
      if (el.innerText !== value) el.innerText = value;
    } else {
      if (el.textContent !== value) el.textContent = value;
    }
  }

  function looksVisible(el) {
    if (!el) return false;
    if (el.getClientRects && el.getClientRects().length) return true;
    if (typeof el.offsetWidth === "number" && typeof el.offsetHeight === "number") {
      return el.offsetWidth > 0 || el.offsetHeight > 0;
    }
    return true;
  }


function replace48mToken(url) {
  if (!url || typeof url !== "string") return url;

  var out = url;

  // replace 48m → upfront
  out = out.replace(/(^|[^a-z0-9])48m([^a-z0-9]|$)/gi, function (m, p1, p2) {
    return p1 + "upfront" + p2;
  });

  // remove "-etv"
  out = out.replace(/-etv/gi, "");

  return out;
}

  function getQueryParam(url, key) {
    if (!url || typeof url !== "string") return null;
    var qIndex = url.indexOf("?");
    if (qIndex === -1) return null;

    var query = url.slice(qIndex + 1);
    var hIndex = query.indexOf("#");
    if (hIndex > -1) query = query.slice(0, hIndex);

    var parts = query.split("&");
    for (var i = 0; i < parts.length; i++) {
      if (!parts[i]) continue;
      var kv = parts[i].split("=");
      var k = decodeURIComponent((kv[0] || "").replace(/\+/g, " "));
      if (k === key) return decodeURIComponent((kv[1] || "").replace(/\+/g, " "));
    }
    return null;
  }

  function setQueryParam(url, key, value) {
    if (!url || typeof url !== "string") return url;
    if (!key) return url;

    var hashIndex = url.indexOf("#");
    var hash = hashIndex > -1 ? url.slice(hashIndex) : "";
    var base = hashIndex > -1 ? url.slice(0, hashIndex) : url;

    var qIndex = base.indexOf("?");
    var path = qIndex > -1 ? base.slice(0, qIndex) : base;
    var query = qIndex > -1 ? base.slice(qIndex + 1) : "";

    var parts = query ? query.split("&") : [];
    var found = false;

    for (var i = 0; i < parts.length; i++) {
      if (!parts[i]) continue;
      var kv = parts[i].split("=");
      var k = decodeURIComponent((kv[0] || "").replace(/\+/g, " "));
      if (k === key) {
        parts[i] = encodeURIComponent(key) + "=" + encodeURIComponent(value);
        found = true;
      }
    }

    if (!found) parts.push(encodeURIComponent(key) + "=" + encodeURIComponent(value));

    var newQuery = parts.filter(Boolean).join("&");
    return path + (newQuery ? "?" + newQuery : "") + hash;
  }

  function normaliseModalSc(sc) {
    if (!sc || typeof sc !== "string") return sc;
    var out = sc;
    out = out.replace(/-etv/gi, "");
    out = out.replace(/(^|[^a-z0-9])48m([^a-z0-9]|$)/gi, function (m, p1, p2) {
      return p1 + "upfront" + p2;
    });
    out = out.replace(/-upfront-upfront/gi, "-upfront");
    return out;
  }

  function getOpenModal() {
    var modal = document.querySelector('div[role="dialog"][aria-modal="true"][data-skyui-core^="Modal"]');
    if (modal && looksVisible(modal)) return modal;

    var candidates = document.querySelectorAll('[data-skyui-core^="Modal"][role="dialog"], [data-skyui-core^="Modal"]');
    for (var i = 0; i < candidates.length; i++) {
      if (looksVisible(candidates[i])) return candidates[i];
    }
    return null;
  }

  function updateGetStartedCtas(card) {
    if (!card) return;

    var ctas = card.querySelectorAll('[data-tracking-label*="get-started"]');
    for (var i = 0; i < ctas.length; i++) {
      var el = ctas[i];

      if (el.hasAttribute("data-tracking-url")) {
        var tUrl = el.getAttribute("data-tracking-url");
        var newTUrl = replace48mToken(tUrl);
        if (newTUrl !== tUrl) el.setAttribute("data-tracking-url", newTUrl);
      }

      var a =
        (el.tagName && el.tagName.toLowerCase() === "a" && el) ||
        el.querySelector("a") ||
        (el.closest && el.closest("a"));

      if (a && a.getAttribute) {
        var href = a.getAttribute("href");
        var newHref = replace48mToken(href);
        if (newHref !== href) a.setAttribute("href", newHref);
      }
    }
  }

  function updatePriceArea(container, priceTestId, opts) {
    if (!container || !opts) return;

    var priceArea = container.querySelector('[data-test-id="' + priceTestId + '"]');
    if (!priceArea) return;

    var priceComponent = priceArea.querySelector('[data-skyui-core^="Price"]');
    if (priceComponent) {
      var vhText = priceComponent.querySelector('[data-skyui-core^="VisuallyHiddenText"]');
      if (vhText && opts.vhText) setText(vhText, opts.vhText);

      var spans = priceComponent.querySelectorAll("span");
      for (var i = 0; i < spans.length; i++) {
        var raw = spans[i].textContent || "";
        var t = raw.replace(/\s+/g, " ").trim();
        if (!t) continue;

        if (t.charAt(0) === "£") {
          var wanted = "£" + opts.price;
          if (raw !== wanted) spans[i].textContent = wanted;
          continue;
        }

        var lower = t.toLowerCase();
        if ((lower.indexOf("/month") > -1 || lower.indexOf("/mo") > -1) && opts.suffix) {
          if (raw !== opts.suffix) spans[i].textContent = opts.suffix;
        }
      }
    }

    var markdown = priceArea.querySelector('[data-skyui-core^="Markdown"]');
    if (markdown && opts.bodyCopy) setText(markdown, opts.bodyCopy);
  }

  function updateSmallPrint(card, smallPrint) {
    if (!card || !smallPrint) return;
    var disclaimer = card.querySelector('[data-test-id^="deal-card-"][data-test-id$="-deal-disclaimer"]');
    if (disclaimer) setText(disclaimer, smallPrint);
  }

  function updateCard(card, opts) {
    if (!card || !opts) return;
    updatePriceArea(card, "price", opts.card);
    updateSmallPrint(card, opts.card.smallPrint);
    updateGetStartedCtas(card);
  }

  var modalContext = { source: null, openedAt: 0 };
  var wiredEls = typeof WeakSet !== "undefined" ? new WeakSet() : null;

  function clearModalContextIfStale() {
    if (!modalContext.source) return;
    if (modalContext.openedAt && Date.now() - modalContext.openedAt > 15000) {
      modalContext.source = null;
      modalContext.openedAt = 0;
    }
  }

  function clearModalContextIfClosed() {
    var modal = getOpenModal();
    if (!modal && modalContext.source) {
      modalContext.source = null;
      modalContext.openedAt = 0;
    }
  }

  function wireWhatsIncludedClick(card, source) {
    if (!card) return;

    if (wiredEls) {
      if (wiredEls.has(card)) return;
      wiredEls.add(card);
    } else {
      if (card.__skyModalWired) return;
      card.__skyModalWired = true;
    }

    card.addEventListener(
      "click",
      function (e) {
        if (!e || e.defaultPrevented) return;
        var target = e.target;
        if (!target || !target.closest) return;

        var cta = target.closest('[data-tracking-label*="whats-included"], [data-tracking-label*="whats included"]');
        if (!cta) return;

        if (!cta.closest("a") && !cta.closest('button,[role="button"]')) return;

        modalContext.source = source;
        modalContext.openedAt = Date.now();
      },
      true
    );
  }

  function findModalSmallPrintElement(modal) {
    if (!modal) return null;

    var textEls = modal.querySelectorAll('[data-skyui-core^="Text"]');
    var best = null;

    for (var i = 0; i < textEls.length; i++) {
      var txt = (textEls[i].textContent || "").replace(/\s+/g, " ").trim().toLowerCase();
      if (!txt) continue;

      if (txt.indexOf("subject to status") > -1 || txt.indexOf("offer ends") > -1 || txt.indexOf("18+") > -1) {
        best = textEls[i];
        break;
      }
    }

    if (!best && textEls.length) best = textEls[textEls.length - 1];
    return best;
  }

  function updateModalLinks(modal) {
    if (!modal) return;

    var links = modal.querySelectorAll("a[href]");
    for (var i = 0; i < links.length; i++) {
      var a = links[i];
      var href = a.getAttribute("href");
      if (!href) continue;

      var newHref = replace48mToken(href);

      var sc = getQueryParam(newHref, "sc");
      if (sc) {
        var newSc = normaliseModalSc(sc);
        if (newSc && newSc !== sc) newHref = setQueryParam(newHref, "sc", newSc);
      }

      if (newHref !== href) a.setAttribute("href", newHref);
    }
  }

  function updateModalPriceAndLegals(modal, opts) {
    if (!modal || !opts) return;

    updatePriceArea(modal, "modal-price", opts.modal);

    var smallPrintEl = findModalSmallPrintElement(modal);
    if (smallPrintEl && opts.modal.smallPrint) setText(smallPrintEl, opts.modal.smallPrint);
  }

  function updateOpenModalIfFromOurCards() {
    clearModalContextIfClosed();
    clearModalContextIfStale();
    if (!modalContext.source) return;

    var modal = getOpenModal();
    if (!modal) return;

    updateModalLinks(modal);

    if (modalContext.source === "byob") {
      updateModalPriceAndLegals(modal, DEALS.byob);
    } else {
      updateModalPriceAndLegals(modal, DEALS.air);
    }
  }

  function updateCards() {
    var airCard = document.querySelector('[aria-labelledby="heading-Sky_Glass_Air"]');
    if (airCard) {
      wireWhatsIncludedClick(airCard, "air");
      updateCard(airCard, DEALS.air);
    }

    var byobCard = document.querySelector('[aria-labelledby="heading-Sky_Glass_BYOB"]');
    if (byobCard) {
      wireWhatsIncludedClick(byobCard, "byob");
      updateCard(byobCard, DEALS.byob);
    }

    updateOpenModalIfFromOurCards();
  }

  function shouldRunUpdate() {
    if (document.querySelector('[aria-labelledby="heading-Sky_Glass_Air"]')) return true;
    if (document.querySelector('[aria-labelledby="heading-Sky_Glass_BYOB"]')) return true;
    if (getOpenModal()) return true;
    return false;
  }

  updateCards();

  var scheduled = false;
  function scheduleUpdate() {
    if (scheduled) return;
    if (!shouldRunUpdate()) return;

    scheduled = true;
    requestAnimationFrame(function () {
      scheduled = false;
      updateCards();
    });
  }

  if (document.body) {
    new MutationObserver(scheduleUpdate).observe(document.body, { childList: true, subtree: true });
  }
})();
