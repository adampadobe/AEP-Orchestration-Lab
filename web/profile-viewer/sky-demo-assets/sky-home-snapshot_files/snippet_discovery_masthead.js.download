"value": function($){var hasInitialised = false;

// Get tracking label from menu item
function getTrackingLabel(li) {
  var link = li.querySelector('a');
  if (!link) return '';

  var label = link.getAttribute('data-tracking-label');
  return label || '';
}

// Reorder menu items based on priority
function reorderMenu(menu) {
  var items = Array.prototype.slice.call(
    menu.querySelectorAll('.user-menu-list-item')
  );

  if (!items.length) return;

  var priorityMap = {
    "masthead_user_bills_and_payments": 1,
    "masthead_user_your_products": 2,
    "masthead_user_order_tracking": 3,
    "masthead_user_my_details": 4,
    "masthead_user_product_settings": 5,
    "masthead_user_message_centre": 6,
    "masthead_user_service_checker": 7,
    "masthead_rewards_and_extras": 8,
    "masthead_user_moving_home": 9,
    "masthead_user_yahoo_mail": 10,
    "masthead_user_refer_a_friend": 11
  };

  var sorted = items.slice().sort(function (a, b) {
    var aPriority = priorityMap[getTrackingLabel(a)] || 999;
    var bPriority = priorityMap[getTrackingLabel(b)] || 999;
    return aPriority - bPriority;
  });

  var changed = items.some(function (item, i) {
    return item !== sorted[i];
  });

  if (!changed) return;

  var fragment = document.createDocumentFragment();
  sorted.forEach(function (el) {
    fragment.appendChild(el);
  });

  menu.appendChild(fragment);
}

// Simple debounce
function debounce(fn, delay) {
  var timer;
  return function () {
    clearTimeout(timer);
    timer = setTimeout(fn, delay);
  };
}

// Initialise once menu is open
function init(menu) {
  if (hasInitialised) return;
  if (!menu) return;

  hasInitialised = true;

  reorderMenu(menu);

  var debouncedReorder = debounce(function () {
    reorderMenu(menu);
  }, 100);

  var menuObserver = new MutationObserver(function () {
    debouncedReorder();
  });

  menuObserver.observe(menu, { childList: true });
}

// Check if menu is open
function isMenuOpen() {
  var toggle = document.querySelector('.user-menu-toggle');
  return toggle && toggle.getAttribute('aria-expanded') === 'true';
}

// Main observer: wait for menu open state
var observer = new MutationObserver(function () {
  var toggle = document.querySelector('.user-menu-toggle');
  if (!toggle) return;

  // Only run when dropdown is open
  if (toggle.getAttribute('aria-expanded') !== 'true') return;

  var firstItem = document.querySelector('.user-menu-list-item');
  if (!firstItem) return;

  var menu = firstItem.parentElement;
  if (!menu) return;

  init(menu);
});

// Watch for aria-expanded changes (menu open/close)
observer.observe(document.body, {
  attributes: true,
  subtree: true,
  attributeFilter: ['aria-expanded']
});
}}]}]}], "weightDistributions": [{"entityId": "5735705263996928", "endOfRange": 5000}, {"entityId": "5877371253817344", "endOfRange": 10000}], "name": "IA_768_ReorderItemsInAccountNav", "bucketingStrategy": null, "experimentMetadata": {"allocationPolicy": "manual", "layerId": "5385151845236736"}, "deployed": false}], "policy": "single_experiment", "viewIds": ["5318678099525632"], "weightDistributions": null, "decisionMetadata": null, "concluded": false}, {"changes": null, "id": "5616637026500608", "name": "demo menu ui", "commitId": "5078934098804736", "groupId": null, "holdback": 0, "activation": {}, "integrationSettings": {}, "integrationStringVersion": 2, "experiments": [{"audienceIds": ["and", "24783611039"], "audienceName": "QA: Cookie", "changes": null, "id": "6297646302756864", "integrationSettings": null, "variations": [{"id": "5047578421624832", "name": "Original", "actions": []}, {"id": "5483491480043520", "name": "Variation #1", "actions": [{"viewId": "6196735039504384", "changes": [{"id": "31A707D0-D068-4E16-9FB0-CF619FE32A31", "type": "attribute", "dependencies": [], "name": "", "isOpalManaged": false, "selector": "[data-test-id='masthead-search-toggle-button']", "attributes": {}, "css": {}}, {"id": "31A707D0-D068-4E16-9FB0-CF619FE32A31-rearrange", "type": "rearrange", "selector": "[data-test-id='masthead-search-toggle-button']", "insertSelector": "[data-test-id='user-menu-toggle'] > span > [data-test-id='masthead-chevron-down-linear-icon']", "operator": "after", "dependencies": ["31A707D0-D068-4E16-9FB0-CF619FE32A31"]}, {"id": "E3ED8CBB-D192-4CF2-8285-14999C1B24A1", "type": "attribute", "dependencies": ["31A707D0-D068-4E16-9FB0-CF619FE32A31-rearrange"], "name": "", "isOpalManaged": false, "selector": "[data-test-id='masthead-alerts-toggle-button']", "attributes": {}, "css": {}}, {"id": "E3ED8CBB-D192-4CF2-8285-14999C1B24A1-rearrange", "type": "rearrange", "selector": "[data-test-id='masthead-alerts-toggle-button']", "insertSelector": "[data-test-id='ma