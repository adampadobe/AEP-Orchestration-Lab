  /*** CONFIG ***/
  var LEGAL_COPY =
    "Sky Broadband Full Fibre 500 available in selected Sky Full Fibre areas. New Customers Only. All prices include Sky Talk Pay As You Talk (new 24-month min. term applies). All speeds measured to router (not device). Wi-Fi performance varies by device and home environment. No traffic management policy. See sky.com for more details and our Usage Policies. Full Fibre 500: Average speeds: 500Mbps (download); 60Mbps (upload). £28pm for 24 months, then £49pm. Price available until 17/06/2026. Prices may change during contract. Set-up fee: £0 (Usually £19.95). General: Compatible line required, otherwise £20 connection charge may apply. Separate 24-month contracts apply to Sky Broadband and Sky Talk. Sky Hub is loaned to you at no cost, it must be returned at the end of the broadband subscription. UK residential customers only. Calls to Sky cost 7p per minute plus your provider’s access charge. Calls to Sky contact centres are free for Sky Talk customers. If you’re not with Sky Talk, calls to 03 numbers cost the same as calls to 01 or 02 numbers and are included in your calls package. If you don’t have a calls package, charges may apply, check your provider’s tariff guide. Up to £200 Switching Credit towards your paid leaving fees. Visit sky.com/help/articles/switching-credit-offer for more info. Price may change during min term. Correct at 21/05/2026. Further terms apply.";

  var MODAL_TITLE = "";

  /*** INTERNAL STATE ***/
  var lastActiveEl = null;
  var isOpen = false;
  var removeKeydown = null;
  var lockedScrollY = 0;
  var savedBodyPaddingRight = "";

  function qs(sel, root) { return (root || document).querySelector(sel); }
  function qsa(sel, root) { return (root || document).querySelectorAll(sel); }

  function ensureModal() {
    if (qs("#optz-legal-modal")) return;

    // Overlay
    var overlay = document.createElement("div");
    overlay.id = "optz-legal-overlay";
    overlay.style.cssText =
      "position:fixed;top:0;left:0;width:100%;height:100%;" +
      "background:rgba(0,0,0,0.6);z-index:9999;display:none;";

    // Modal
    var modal = document.createElement("div");
    modal.id = "optz-legal-modal";
    modal.setAttribute("role", "dialog");
    modal.setAttribute("aria-modal", "true");
    modal.setAttribute("aria-labelledby", "optz-legal-title");
    modal.style.cssText =
      "position:fixed;top:50%;left:50%;transform:translate(-50%,-50%);" +
      "background:#fff;padding:20px;max-width:640px;width:92%;" +
      "max-height:80vh;overflow:auto;z-index:10000;display:none;" +
      "border-radius:12px;box-shadow:0 10px 30px rgba(0,0,0,0.25);";

    // Header
    var header = document.createElement("div");
    header.style.cssText = "display:flex;align-items:center;justify-content:space-between;gap:12px;";

    var title = document.createElement("div");
    title.id = "optz-legal-title";
    title.textContent = MODAL_TITLE;
    title.style.cssText = "font-size:18px;font-weight:600;";

    var closeBtn = document.createElement("button");
    closeBtn.type = "button";
    closeBtn.setAttribute("aria-label", "Close");
    closeBtn.innerHTML = "&#215;";
    closeBtn.style.cssText =
      "cursor:pointer;font-size:26px;line-height:1;border:0;background:transparent;padding:0 4px;";

    var content = document.createElement("div");
    content.id = "optz-legal-content";
    content.style.cssText = "margin-top:12px;white-space:pre-wrap;font-size:14px;line-height:1.4;";

    header.appendChild(title);
    header.appendChild(closeBtn);
    modal.appendChild(header);
    modal.appendChild(content);

    function onOverlayClick(e) {
      // only close if click is directly on overlay, not bubbled from modal
      if (e && e.target === overlay) closeModal();
    }

    overlay.addEventListener("click", onOverlayClick);
    closeBtn.addEventListener("click", closeModal);

    document.body.appendChild(overlay);
    document.body.appendChild(modal);
  }

  /*** SCROLL LOCK (robust incl iOS) ***/
  function lockScroll() {
    var docEl = document.documentElement;

    lockedScrollY = window.pageYOffset || docEl.scrollTop || document.body.scrollTop || 0;

    // avoid layout shift when scrollbar disappears
    var scrollBarWidth = window.innerWidth - docEl.clientWidth;
    savedBodyPaddingRight = document.body.style.paddingRight || "";
    if (scrollBarWidth > 0) document.body.style.paddingRight = scrollBarWidth + "px";

    // lock body in place
    document.body.style.position = "fixed";
    document.body.style.top = (-lockedScrollY) + "px";
    document.body.style.left = "0";
    document.body.style.right = "0";
    document.body.style.width = "100%";
  }

  function unlockScroll() {
    document.body.style.position = "";
    document.body.style.top = "";
    document.body.style.left = "";
    document.body.style.right = "";
    document.body.style.width = "";
    document.body.style.paddingRight = savedBodyPaddingRight;

    window.scrollTo(0, lockedScrollY);
  }

  /*** FOCUS MANAGEMENT + TRAP ***/
  function isVisible(el) {
    // cheap visibility check
    return !!(el && (el.offsetWidth || el.offsetHeight || el.getClientRects().length));
  }

  function getFocusable(container) {
    var nodes = qsa(
      'a[href],area[href],button:not([disabled]),input:not([disabled]),select:not([disabled]),' +
      'textarea:not([disabled]),iframe,[tabindex]:not([tabindex="-1"]),[contenteditable="true"]',
      container
    );

    var out = [];
    for (var i = 0; i < nodes.length; i++) {
      var n = nodes[i];
      // skip hidden/disabled
      if (!isVisible(n)) continue;
      if (n.getAttribute("aria-hidden") === "true") continue;
      out.push(n);
    }
    return out;
  }

  function focusFirstInModal() {
    var modal = qs("#optz-legal-modal");
    if (!modal) return;

    var focusables = getFocusable(modal);
    if (focusables.length) {
      focusables[0].focus();
    } else {
      modal.setAttribute("tabindex", "-1");
      modal.focus();
    }
  }

  function trapKeydown(e) {
    if (!isOpen) return;

    e = e || window.event;
    var key = e.key || e.keyCode;

    // ESC closes
    if (key === "Escape" || key === "Esc" || key === 27) {
      if (e.preventDefault) e.preventDefault();
      closeModal();
      return;
    }

    // TAB trap
    if (!(key === "Tab" || key === 9)) return;

    var modal = qs("#optz-legal-modal");
    if (!modal) return;

    var focusables = getFocusable(modal);
    if (!focusables.length) {
      if (e.preventDefault) e.preventDefault();
      return;
    }

    var first = focusables[0];
    var last = focusables[focusables.length - 1];
    var active = document.activeElement;
    var shift = !!e.shiftKey;

    // If focus somehow moved outside, pull it back in
    if (!modal.contains(active)) {
      if (e.preventDefault) e.preventDefault();
      first.focus();
      return;
    }

    if (shift && active === first) {
      if (e.preventDefault) e.preventDefault();
      last.focus();
      return;
    }

    if (!shift && active === last) {
      if (e.preventDefault) e.preventDefault();
      first.focus();
      return;
    }
  }

  /*** OPEN/CLOSE ***/
  function openModal(copy, openerEl) {
    ensureModal();

    lastActiveEl = openerEl || document.activeElement;

    var overlay = qs("#optz-legal-overlay");
    var modal = qs("#optz-legal-modal");
    var content = qs("#optz-legal-content");
    var title = qs("#optz-legal-title");

    // Update copy + title
    if (title) title.textContent = MODAL_TITLE;
    if (content) content.textContent = copy;

    // Show
    overlay.style.display = "block";
    modal.style.display = "block";

    // Lock scroll
    lockScroll();

    // Mark open + bind trap
    isOpen = true;
    if (!removeKeydown) {
      var handler = function (ev) { trapKeydown(ev); };
      document.addEventListener("keydown", handler, true);
      removeKeydown = function () {
        document.removeEventListener("keydown", handler, true);
      };
    }

    // Move focus into modal (required behaviour)
    focusFirstInModal();
  }

  function closeModal() {
    if (!qs("#optz-legal-modal")) return;

    var overlay = qs("#optz-legal-overlay");
    var modal = qs("#optz-legal-modal");

    overlay.style.display = "none";
    modal.style.display = "none";

    // Unbind trap
    isOpen = false;
    if (removeKeydown) {
      removeKeydown();
      removeKeydown = null;
    }

    // Unlock scroll
    unlockScroll();

    // Return focus to opener (required behaviour)
    if (lastActiveEl && lastActiveEl.focus) {
      try { lastActiveEl.focus(); } catch (e) {}
    }
    lastActiveEl = null;
  }

  /*** CLICK WIRING (event delegation; no rebinding needed on React re-renders) ***/
  document.addEventListener("click", function (e) {
    e = e || window.event;
    var target = e.target;

    // Find nearest trigger anchor
    while (target && target !== document && !(target.tagName && target.tagName.toLowerCase() === "a")) {
      target = target.parentNode;
    }
    if (!target || target === document) return;

    // Only handle our links
    if (target.getAttribute && target.getAttribute("data-legal-trigger")) {
      if (e.preventDefault) e.preventDefault();
      openModal(LEGAL_COPY, target);
      return false;
    }
  }, true);

})();
