"allocationPolicy": "manual", "layerId": "5162085722619904"}, "deployed": false}], "policy": "single_experiment", "viewIds": ["28370991178", "4791468263473152"], "weightDistributions": null, "decisionMetadata": null, "concluded": false}, {"changes": null, "id": "6280935272873984", "name": "EXP-MERCH-16 Deal card titles", "commitId": "4881226905944064", "groupId": null, "holdback": 0, "activation": {}, "integrationSettings": {}, "integrationStringVersion": 2, "experiments": [{"audienceIds": null, "audienceName": "Everyone else", "changes": null, "id": "5335389632724992", "integrationSettings": null, "variations": [{"id": "5758428442787840", "name": "Original", "actions": []}, {"id": "6190704016228352", "name": "Variation #1", "actions": [{"viewId": "28370991178", "changes": [{"id": "128EF022-393B-49E4-A5FA-8F6F50C4559C", "type": "custom_code", "value": function($){(function () {
  var EXP_ID = 'sky-deal-card-title-bullets-v2';
  if (window[EXP_ID]) return;
  window[EXP_ID] = true;

  function normalisePart(text) {
    return text.replace(/\s+/g, ' ').trim();
  }

  function splitTitle(title) {
    return title
      .replace(/\s*&\s*/g, '|')
      .replace(/\s*,\s*/g, '|')
      .split('|')
      .map(normalisePart)
      .filter(Boolean);
  }

  function formatHeading(heading) {
    if (!heading || heading.getAttribute('data-opt-title-formatted') === 'true') return;

    var original = normalisePart(heading.textContent);
    var parts = splitTitle(original);

    if (parts.length < 2) return;

    heading.setAttribute('data-opt-title-formatted', 'true');
    heading.setAttribute('data-original-title', original);

    heading.innerHTML = parts
      .map(function (part) {
        return '<span class="opt-deal-title-line">- ' + part + '</span>';
      })
      .join('');
  }

  function updateDealCards() {
    var cards = document.querySelectorAll('[data-test-id^="deal-card-"]');

    for (var i = 0; i < cards.length; i++) {
      var heading =
        cards[i].querySelector('h1, h2, h3') ||
        cards[i].querySelector('[id^="heading-"]');

      formatHeading(heading);
    }
  }

  function addStyles() {
    if (document.getElementById(EXP_ID + '-styles')) return;

    var style = document.createElement('style');
    style.id = EXP_ID + '-styles';
    style.textContent =
      '.opt-deal-title-line{' +
        'display:block;' +
        'line-height:1.2;' +
      '}';
    document.head.appendChild(style);
  }

  addStyles();
  updateDealCards();

  var observer = new MutationObserver(function () {
    updateDealCards();
  });

  observer.observe(document.documentElement, {
    childList: true,
    subtree: true
  });
})();
}, "dependencies": []}]}]}], "weightDistributions": [{"entityId": "5758428442787840", "endOfRange": 5000}, {"entityId": "6190704016228352", "endOfRange": 10000}], "name": "EXP-MERCH-16 Deal card titles", "bucketingStrategy": null, "experimentMetadata": {"allocationPolicy": "manual", "layerId": "6280935272873984"}, "deployed": false}], "policy": "single_experiment", "viewIds": ["28370991178"], "weightDistributions": null, "decisionMetadata": null, "concluded": false}, {"changes": null, "id": "5318037964849152", "name": "EXP-815 Glass Upfront (Merch)", "commitId": "5547918103412736", "groupId": null, "holdback": 0, "activation": {}, "integrationSettings": {}, "integrationStringVersion": 2, "experiments": [{"audienceIds": ["and", "24582981020"], "audienceName": "GB Only (Exclude ROI)", "changes": null, "id": "5564183782096896", "integrationSettings": null, "variations": [{"id": "4724580758061056", "name": "Original", "actions": [{"viewId": "4771445503426560", "changes": []}, {"viewId": "6711110267568128", "changes": []}, {"viewId": "28370991178", "changes": []}]}, {"id": "6059243556569088", "name": "Variation #1", "actions": [{"viewId": "4771445503426560", "changes": [{"id": "6E08B040-BDF6-447B-BACC-F2B79E8C5411", "type": "custom_code", "value": function($){(function () {
  var NEW_COPY =
    'Get the best of Sky and Netflix in one place with Sky TV from only £15pm';

  function updateLegalCopy() {
    var blocks = document.querySelectorAll(
      'thead[data-test-id="table-head"] div[data-skyui-core^="Markdown"]'
    );

    for (var i = 0; i < blocks.length; i++) {
      var block = blocks[i];
      if (!block || block.getAttribute('data-opt-legal-updated') === 'true') continue;

      var html = block.innerHTML;
