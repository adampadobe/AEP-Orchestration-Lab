  var HERO_CONTENT = [
    // Block 1
    {
      title: "Essential TV, everyday low price.",
      body:
        "The biggest and the best of Sky, Netflix and Discovery+. All in one TV package, all on one subscription. From £15/month.",
      cta1: {
        text: "See Sky TV deals",
