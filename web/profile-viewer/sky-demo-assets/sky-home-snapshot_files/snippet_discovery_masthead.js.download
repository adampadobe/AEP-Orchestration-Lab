  var targetHeadingIds = [
    'heading-stream_netflix_sports',
    'heading-stream_netflix_sports_UTV'
  ];

  var copyToRemove = 'Watch straightaway on Sky Go after you order';

  function normalizeText(text) {
    return (text || '').replace(/\s+/g, ' ').trim();
  }

  function getCardByHeadingId(headingId) {
    return document.querySelector('[aria-labelledby="' + headingId + '"]');
  }

  function removeCopyFromCard(card) {
    if (!card) return;

    var spans = card.querySelectorAll('span');

    Array.prototype.forEach.call(spans, function (span) {
      if (normalizeText(span.textContent) !== copyToRemove) return;

      // Remove only the smallest wrapper whose full text is exactly the target copy
      var nodeToRemove = span;

      while (
        nodeToRemove.parentElement &&
        nodeToRemove.parentElement !== card &&
        normalizeText(nodeToRemove.parentElement.textContent) === copyToRemove
      ) {
        nodeToRemove = nodeToRemove.parentElement;
      }

      nodeToRemove.remove();
    });
  }

  function applyChanges() {
    targetHeadingIds.forEach(function (headingId) {
      var card = getCardByHeadingId(headingId);
      removeCopyFromCard(card);
    });
  }

  applyChanges();

  var observer = new MutationObserver(function () {
    applyChanges();
  });

  observer.observe(document.body, {
    childList: true,
    subtree: true
  });

  setTimeout(function () {
    observer.disconnect();
  }, 15000);
})();
