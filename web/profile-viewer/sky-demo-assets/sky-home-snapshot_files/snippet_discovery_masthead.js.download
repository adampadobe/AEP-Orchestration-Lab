-411C-B881-F2D69D348604", "selector": "[data-test-id='exp-hero-ctas-5'] > [data-test-id='exp-hero-cta-secondary-5']"}, {"css": {}, "dependencies": [], "attributes": {"src": "//cdn.optimizely.com/img/2900460605/caecb8c249874063a6576f4a14d131a8.png"}, "type": "attribute", "id": "8F751702-BD75-47BD-97E0-1D35B4CCFFCC", "selector": "[data-test-id='exp-hero-img-2']"}, {"css": {}, "dependencies": [], "attributes": {"src": "//cdn.optimizely.com/img/2900460605/b9281e860bd142d1b3d85f7fbef1e360.png"}, "type": "attribute", "id": "0C87BE63-C42D-4CDF-821E-0B95DDAC4FC2", "selector": "[data-test-id='exp-hero-img-1']"}, {"css": {}, "dependencies": [], "attributes": {"html": "Explore Ultimate TV<span data-exp-chevron=\"\" aria-hidden=\"true\"></span>", "href": "https://www.sky.com/tv?irct=watch-lm-utv"}, "type": "attribute", "id": "8C8EE831-ED10-4F43-9D68-5E52DA36BD9D", "selector": "[data-test-id='exp-hero-ctas-2'] > [data-test-id='exp-hero-cta-secondary-2']"}, {"css": {}, "dependencies": [], "attributes": {"src": "//cdn.optimizely.com/img/2900460605/a2cc0275806f40cf94221cc3514d1419.png"}, "type": "attribute", "id": "4D0BC400-49C4-437B-9BC8-EFEB14F5C840", "selector": "[data-test-id='exp-hero-img-3']"}, {"css": {}, "dependencies": [], "attributes": {"src": "//cdn.optimizely.com/img/2900460605/27825289aabf45f88651d13749692325.png"}, "type": "attribute", "id": "6D7FCFE0-4673-4FFF-B17B-D0CD84951665", "selector": "[data-test-id='exp-hero-img-4']"}, {"css": {}, "dependencies": [], "attributes": {"src": "//cdn.optimizely.com/img/2900460605/8d1d2a0f7f344720b235456c8722f042.png"}, "type": "attribute", "id": "77F1F5AC-ADBB-43E5-9069-39B7CDAFC65A", "selector": "[data-test-id='exp-hero-img-5']"}, {"css": {}, "dependencies": [], "attributes": {"href": "https://www.sky.com/glass/buy/stream/bundle?sc=stream-essential-tv-kids&irct=watch-upsell-kids", "html": "Upgrade now<span data-exp-chevron=\"\" aria-hidden=\"true\"></span>"}, "type": "attribute", "id": "58418045-2344-4B7C-BCAD-AEB8973C1311", "sel