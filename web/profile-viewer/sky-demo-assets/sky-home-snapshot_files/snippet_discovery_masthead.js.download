  var FULL_LEGAL_ULTIMATE =
    "Includes Sky Ultimate TV, Netflix Standard with Ads, Disney+ Standard with Ads, HBO Max Basic with Ads and taste of Hayu. Requires Sky Stream and relevant TV subscriptions. 'Streaming sorted for less than £1 a day' based on £24pm price on 24m contract. £38pm after Min. term. Minimum broadband speed of 25Mbps recommended. 18+. All third party trade marks and copyrights are the property of their respective owners. All rights reserved. New Sky Ultimate TV customers only. Requires Sky Stream and Sky Ultimate TV subscription £24pm on 24 month minimum term. Price and services may change. Upfront fee £0 (usually £20). Requires TV with HDMI port and broadband minimum recommended speed 30Mbps. Order by 9pm Mon-Fri or 3pm Sunday for next day delivery. Excludes Bank Holidays. Sky Stream Pucks are loaned to you at no cost and must be returned when they are no longer registered on your account. Streaming TV account required, manage online at sky.com or via the My Sky app. Email address required for account login. Includes Netflix Standard with Ads (RRP £4.99). Subject to status. 18+. Further terms apply.";

  var FULL_LEGAL_ESSENTIAL =
    "Requires Sky Stream or Sky Glass. Sky Essential TV subscription: £15 pm. 24-month minimum term. Prices may vary during this term. Standard price applies after 24 months (currently £21pm) OR 31-day rolling subscription. Includes Sky Atlantic, Sky Showcase, Sky Sports News, Sky Sports Mix, Sky Sports Racing, Netflix Standard with ads and discovery+ Basic. All content on Sky Stream and Sky Glass is streamed via broadband, minimum speed of 30Mbps recommended. 18+. UK, CI, IoM only.";

  /** -------------------------
   * HELPERS
   -------------------------- */
  function getText(el) {
    return (el && (el.textContent || el.innerText) || "").replace(/^\s+|\s+$/g, "");
  }

  function getType(card) {
    var h3 = card.querySelector("h3");
    var t = getText(h3).toLowerCase();

    if (t.indexOf("ultimate") > -1) return "ultimate";
    if (t.indexOf("essential") > -1) return "essential";
    return null;
  }

  /** -------------------------
   * MODAL STATE
   -------------------------- */
  var lastTrigger = null;
  var scrollY = 0;
  var removeKeydown = null;

  /** -------------------------
   * MODAL CREATION
   -------------------------- */
  function ensureModal() {
    if (document.getElementById("optz-legal-modal")) return;

    var overlay = document.createElement("div");
    overlay.id = "optz-legal-overlay";
    overlay.style.cssText =
      "position:fixed;top:0;left:0;width:100%;height:100%;" +
      "background:rgba(0,0,0,0.6);z-index:9999;display:none;";

    var modal = document.createElement("div");
    modal.id = "optz-legal-modal";
    modal.setAttribute("role", "dialog");
    modal.setAttribute("aria-modal", "true");
    modal.setAttribute("tabindex", "-1");
    modal.style.cssText =
      "position:fixed;top:50%;left:50%;transform:translate(-50%,-50%);" +
      "background:#fff;padding:20px;max-width:600px;width:90%;" +
      "max-height:80vh;overflow:auto;z-index:10000;display:none;";

    var header = document.createElement("div");
    header.style.cssText = "display:flex;justify-content:space-between;align-items:center;";

