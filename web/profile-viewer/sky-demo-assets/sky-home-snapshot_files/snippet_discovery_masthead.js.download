], "attributes": {"href": "https://www.sky.com/glass/buy/personalise-sky-glass-air?sc=glass-air-large-upfront&irct=web-glass-discovery-tech-specs-65-inch-2-gbr-air-all-buy-now"}, "type": "attribute", "id": "23CDDD58-FC86-4EAA-88B4-AF199A67DD65", "selector": "[data-test-id='cta-primary-specs-comparison-table-row-group-4-row-0-row-cell-0']"}, {"css": {}, "dependencies": [], "attributes": {"href": "https://sky.com/glass/buy/personalise-sky-glass?sc=glass-gen2-large-upfront&irct=web-glass-discovery-tech-specs-65-inch-2-gbr-gen2-all-buy-now"}, "type": "attribute", "id": "FB096CFF-4921-45D8-999B-9BEA0434C1C8", "selector": "[data-test-id='cta-primary-specs-comparison-table-row-group-4-row-0-row-cell-1']"}]}, {"viewId": "6753521026990080", "changes": [{"id": "4E302A81-0EFF-425F-8186-89DF8BDC848D", "type": "custom_code", "value": function($){(function () {
  var NEW_COPY =
    'Get the best of Sky and Netflix in one place with Sky TV from only £15pm.';

  function updateLegalCopy() {
    var blocks = document.querySelectorAll(
      'thead[data-test-id="table-head"] div[data-skyui-core^="Markdown"]'
    );

    for (var i = 0; i < blocks.length; i++) {
      var block = blocks[i];
      if (!block || block.getAttribute('data-opt-legal-updated') === 'true') continue;

      var html = block.innerHTML;
      if (!html) continue;

      if (
        html.indexOf('Over a 48-month loan.') === -1 ||
        html.indexOf('Requires streaming TV subscription from £15pm') === -1
      ) {
        continue;
      }

      var brMatch = html.match(/<br\s*\/?>/i);
      if (!brMatch) continue;

      var splitIndex = html.indexOf(brMatch[0], html.indexOf('a month'));
      if (splitIndex === -1) continue;

      var preserved = html.slice(0, splitIndex + brMatch[0].length);
      block.innerHTML = preserved + ' ' + NEW_COPY;
      block.setAttribute('data-opt-legal-updated', 'true');
    }
  }

  updateLegalCopy();

  if (document.body) {
    new MutationObserver(function () {
      updateLegalCopy();
    }).observe(document.body, {
      childList: true,
      subtree: true
    });
  }
})();
