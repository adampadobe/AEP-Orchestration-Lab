      e.preventDefault();
      last.focus();
    } else if (!e.shiftKey && document.activeElement === last) {
      e.preventDefault();
      first.focus();
    }
  }

  function handleKeydown(e) {
    if (e.key === "Escape" || e.keyCode === 27) {
      closeModal();
      return;
    }
    trapFocus(e);
  }

  /** -------------------------
   * OPEN / CLOSE
   -------------------------- */
  function openModal(copy, trigger) {
    ensureModal();

    lastTrigger = trigger;

    var modal = document.getElementById("optz-legal-modal");
    var overlay = document.getElementById("optz-legal-overlay");

    document.getElementById("optz-legal-content").textContent = copy;

    overlay.style.display = "block";
    modal.style.display = "block";

    lockScroll();

    modal.focus();

    document.addEventListener("keydown", handleKeydown, true);
    removeKeydown = true;
  }

  function closeModal() {
    var modal = document.getElementById("optz-legal-modal");
    var overlay = document.getElementById("optz-legal-overlay");

    if (!modal) return;

    overlay.style.display = "none";
    modal.style.display = "none";

    unlockScroll();

    if (removeKeydown) {
      document.removeEventListener("keydown", handleKeydown, true);
      removeKeydown = null;
    }

    if (lastTrigger && lastTrigger.focus) {
      lastTrigger.focus();
    }
  }

  /** -------------------------
   * CARD PROCESSING (UNCHANGED LOGIC)
   -------------------------- */
  function processCard(card) {
    var type = getType(card);
    if (!type) return;

    var spans = card.querySelectorAll("span");
    var legalSpan = null;

    for (var i = spans.length - 1; i >= 0; i--) {
      var txt = getText(spans[i]);
      if (txt && txt.length > 15 && txt.indexOf("From £") === -1) {
        legalSpan = spans[i];
        break;
      }
    }

    if (!legalSpan) return;

    if (legalSpan.querySelector('[data-optz-legal-link]')) return;

    var link = document.createElement("a");
    link.href = "#";
    link.textContent = "See all legals";
    link.setAttribute("data-optz-legal-link", "true");
    link.style.marginLeft = "4px";
    link.style.textDecoration = "underline";

    link.onclick = function (e) {
      e.preventDefault();

      var copy = type === "ultimate"
        ? FULL_LEGAL_ULTIMATE
        : FULL_LEGAL_ESSENTIAL;

      openModal(copy, link);
    };

    legalSpan.appendChild(link);
  }

  function run() {
    var cards = document.querySelectorAll('[data-test-id="package-section-card"]');

